@model WebApplication1.Models.DetalleOrdenCompra

@{
    ViewBag.Title = "Agregar Detalle de Orden de Compra";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    .detalle-form-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .detalle-form-container {
        max-width: 950px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .detalle-form-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .detalle-form-title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #111827;
    }

    .detalle-form-subtitle {
        margin: 5px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .detalle-form-card {
        background: #fff;
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    }

    .form-label-custom {
        font-weight: 600;
        color: #111827;
        margin-bottom: 6px;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        min-height: 45px;
        border: 1px solid #d1d5db;
        box-shadow: none;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #111827;
            box-shadow: 0 0 0 0.15rem rgba(17, 24, 39, 0.15);
        }

    .btn-detalle-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 18px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-detalle-primary:hover {
            background: #000;
            color: #fff;
        }

    .btn-detalle-secondary {
        background: #16a34a;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 18px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-detalle-secondary:hover {
            background: #15803d;
            color: #fff;
        }

    .text-danger {
        font-size: 13px;
        margin-top: 4px;
        display: block;
    }

    .alert-custom {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 20px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .detalle-form-card {
            padding: 18px;
        }
    }
</style>

<section class="detalle-form-section">
    <div class="detalle-form-container">

        <div class="detalle-form-head">
            <div>
                <h2 class="detalle-form-title">Agregar Producto a la Orden</h2>
                <p class="detalle-form-subtitle">
                    Registra un nuevo producto dentro del detalle de la orden seleccionada.
                </p>
            </div>

            <a href="@Url.Action("VerDetalleOrdenCompra", "DetalleOrdenCompra", new { q = Model.OrdenCompraID })"
               class="btn btn-detalle-secondary">
                Volver al detalle
            </a>
        </div>

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert-custom">
                @ViewBag.Mensaje
            </div>
        }

    <div class="detalle-form-card">
        @using (Html.BeginForm("AgregarDetalleOrdenCompra", "DetalleOrdenCompra", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            @Html.HiddenFor(model => model.OrdenCompraID)
            @Html.HiddenFor(model => model.DetalleOrdenCompraID)

            <div class="row g-3">

                <div class="col-md-6">
                    <label class="form-label-custom">ID de la Orden</label>
                    <input type="text" class="form-control" value="@Model.OrdenCompraID" readonly />
                </div>

                <div class="col-md-6">
                    <label class="form-label-custom">Producto</label>
                    @Html.DropDownListFor(model => model.ProductoID,
                        ViewBag.Productos as SelectList,
                        "-- Seleccione un producto --",
                        new { @class = "form-select" })
                    @Html.ValidationMessageFor(model => model.ProductoID, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label-custom">Cantidad</label>
                    @Html.TextBoxFor(model => model.Cantidad,
                        new { @class = "form-control", @type = "number", min = "1", id = "Cantidad" })
                    @Html.ValidationMessageFor(model => model.Cantidad, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label-custom">Precio de Compra</label>
                    @Html.TextBoxFor(model => model.PrecioCompra,
                        new { @class = "form-control", @type = "number", step = "0.01", min = "0.01", id = "PrecioCompra" })
                    @Html.ValidationMessageFor(model => model.PrecioCompra, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label-custom">Subtotal</label>
                    <input type="text" class="form-control" id="SubtotalVista" readonly />
                </div>

                <div class="col-12 mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-detalle-primary">
                        Guardar Detalle
                    </button>

                    <a href="@Url.Action("VerDetalleOrdenCompra", "DetalleOrdenCompra", new { q = Model.OrdenCompraID })"
                       class="btn btn-outline-secondary">
                        Cancelar
                    </a>
                </div>

            </div>
        }
    </div>

    </div>
</section>

@section Scripts {
    <script>
        function calcularSubtotal() {
            var cantidad = parseFloat(document.getElementById("Cantidad").value) || 0;
            var precio = parseFloat(document.getElementById("PrecioCompra").value) || 0;
            var subtotal = cantidad * precio;

            document.getElementById("SubtotalVista").value = subtotal.toFixed(2);
        }

        document.addEventListener("DOMContentLoaded", function () {
            var cantidadInput = document.getElementById("Cantidad");
            var precioInput = document.getElementById("PrecioCompra");

            if (cantidadInput) {
                cantidadInput.addEventListener("input", calcularSubtotal);
            }

            if (precioInput) {
                precioInput.addEventListener("input", calcularSubtotal);
            }

            calcularSubtotal();
        });
    </script>
}