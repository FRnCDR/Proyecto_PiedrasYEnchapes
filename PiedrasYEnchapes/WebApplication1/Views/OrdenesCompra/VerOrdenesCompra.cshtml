@model List<WebApplication1.Models.OrdenCompra>

@{
    ViewBag.Title = "Órdenes de Compra";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";

    var totalOrdenes = Model != null ? Model.Count : 0;
    var ordenesActivas = Model != null ? Model.Count(x => x.Estado) : 0;
    var ordenesPendientes = Model != null ? Model.Count(x => x.EstadoRecepcion == "Pendiente") : 0;
    var montoTotal = Model != null ? Model.Sum(x => x.Total) : 0;
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    .ordenes-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .ordenes-container {
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .ordenes-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .ordenes-title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #111827;
    }

    .ordenes-subtitle {
        margin: 5px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .ordenes-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-ordenes-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-ordenes-primary:hover {
            background: #000;
            color: #fff;
        }

    .btn-ordenes-secondary {
        background: #16a34a;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-ordenes-secondary:hover {
            background: #15803d;
            color: #fff;
        }

    .ordenes-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .ordenes-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        position: relative;
        overflow: hidden;
    }

        .ordenes-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
        }

    .card-total::before {
        background: #2563eb;
    }

    .card-activas::before {
        background: #16a34a;
    }

    .card-pendientes::before {
        background: #f59e0b;
    }

    .card-monto::before {
        background: #7c3aed;
    }

    .ordenes-label {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .ordenes-value {
        font-size: 30px;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
    }

    .ordenes-extra {
        margin-top: 8px;
        font-size: 13px;
        color: #9ca3af;
    }

    .ordenes-alert {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .ordenes-table-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 18px;
    }

    .ordenes-table-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 14px;
    }

    .estado-activo {
        background: #dcfce7;
        color: #166534;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-inactivo {
        background: #fee2e2;
        color: #991b1b;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .recepcion-pendiente {
        background: #fef3c7;
        color: #92400e;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .recepcion-recibida {
        background: #dbeafe;
        color: #1d4ed8;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    table.dataTable thead th {
        background: #111827;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border-bottom: none;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        font-size: 14px;
    }

    .dataTables_wrapper .dataTables_filter input {
        border-radius: 999px;
        border: 1px solid #d1d5db;
        padding: 4px 10px;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 999px !important;
        padding: 4px 9px;
        margin: 0 2px;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: #facc15 !important;
            border-color: #facc15 !important;
            color: #111827 !important;
        }

    .ordenes-filtros {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

        .ordenes-filtros input,
        .ordenes-filtros select {
            border-radius: 999px;
            border: 1px solid #d1d5db;
            padding: 6px 12px;
            font-size: 14px;
        }

    .dataTables_wrapper .dataTables_paginate {
        margin-top: 15px;
        text-align: center;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            background: #f3f4f6 !important;
            border: none !important;
            border-radius: 999px !important;
            padding: 6px 14px !important;
            margin: 0 4px;
            font-size: 14px;
            font-weight: 600;
            color: #111827 !important;
            cursor: pointer !important;
            transition: all 0.2s ease-in-out;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background: #111827 !important;
                color: #fff !important;
                transform: translateY(-1px);
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #facc15 !important;
                color: #111827 !important;
                font-weight: 700;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
                background: #e5e7eb !important;
                color: #9ca3af !important;
                cursor: not-allowed !important;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.previous,
            .dataTables_wrapper .dataTabl
Tables_paginate .paginate_button.next {
                font-weight: 700;
            }es_paginate .paginate_button.next {
                font-weight: 700;
            }

    .acciones-ordenes {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
        align-items: center;
    }

    .btn-accion-orden {
        min-width: 92px;
        height: 36px;
        border: none;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none !important;
        padding: 0 14px;
        transition: all 0.2s ease-in-out;
        cursor: pointer;
        color: #fff;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

        .btn-accion-orden:hover {
            transform: translateY(-1px);
            color: #fff;
            box-shadow: 0 8px 16px rgba(0,0,0,0.12);
        }

    .btn-detalle-orden {
        background: #06b6d4;
    }

        .btn-detalle-orden:hover {
            background: #0891b2;
        }

    .btn-editar-orden {
        background: #f59e0b;
    }

        .btn-editar-orden:hover {
            background: #d97706;
        }

    .btn-recibir-orden {
        background: #2563eb;
    }

        .btn-recibir-orden:hover {
            background: #1d4ed8;
        }

    .btn-desactivar-orden {
        background: #dc2626;
    }

        .btn-desactivar-orden:hover {
            background: #b91c1c;
        }

    .btn-activar-orden {
        background: #16a34a;
    }

        .btn-activar-orden:hover {
            background: #15803d;
        }

    @@media (max-width: 992px) {
        .ordenes-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .ordenes-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .ordenes-grid {
            grid-template-columns: 1fr;
        }

        .ordenes-table-card {
            padding: 12px;
        }
    }
</style>

<section class="ordenes-section">
    <div class="ordenes-container">

        <div class="ordenes-head">
            <div>
                <h2 class="ordenes-title">Órdenes de Compra</h2>
                <p class="ordenes-subtitle">
                    Administra las órdenes registradas y controla su recepción en inventario.
                </p>
            </div>

            <div class="ordenes-actions">
                <a href="@Url.Action("AgregarOrdenCompra", "OrdenesCompra")" class="btn btn-ordenes-primary">
                    Crear Orden
                </a>

                <a href="@Url.Action("VerProveedores", "Proveedor")" class="btn btn-ordenes-secondary">
                    Ver Proveedores
                </a>
            </div>
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="ordenes-alert">
                @TempData["Mensaje"]
            </div>
        }

        <div class="ordenes-grid">
            <div class="ordenes-card card-total">
                <div class="ordenes-label">Total de órdenes</div>
                <div class="ordenes-value">@totalOrdenes</div>
                <div class="ordenes-extra">Órdenes registradas en el sistema</div>
            </div>

            <div class="ordenes-card card-activas">
                <div class="ordenes-label">Órdenes activas</div>
                <div class="ordenes-value">@ordenesActivas</div>
                <div class="ordenes-extra">Órdenes habilitadas actualmente</div>
            </div>

            <div class="ordenes-card card-pendientes">
                <div class="ordenes-label">Pendientes por recibir</div>
                <div class="ordenes-value">@ordenesPendientes</div>
                <div class="ordenes-extra">Órdenes aún no aplicadas a inventario</div>
            </div>

            <div class="ordenes-card card-monto">
                <div class="ordenes-label">Monto total</div>
                <div class="ordenes-value">₡ @montoTotal.ToString("N2")</div>
                <div class="ordenes-extra">Suma total de órdenes registradas</div>
            </div>
        </div>

        <div class="ordenes-filtros">

            <input type="text" id="filtroProveedor" placeholder="Buscar proveedor..." />

            <select id="filtroEstado">
                <option value="">Todos los estados</option>
                <option value="Activo">Activo</option>
                <option value="Inactivo">Inactivo</option>
            </select>

            <select id="filtroRecepcion">
                <option value="">Todas las recepciones</option>
                <option value="Pendiente">Pendiente</option>
                <option value="Recibida">Recibida</option>
            </select>

            <input type="date" id="filtroFechaDesde" />
            <input type="date" id="filtroFechaHasta" />

        </div>

        <div class="ordenes-table-card">
            <h3 class="ordenes-table-title">Listado de órdenes de compra</h3>

            <div class="table-responsive" style="overflow: visible;">
                <table id="tablaOrdenesCompra" class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Proveedor</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th>Recepción</th>
                            <th style="width: 360px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.OrdenCompraID</td>
                                    <td>@item.NombreProveedor</td>
                                    <td>@item.FechaOrden.ToString("dd/MM/yyyy")</td>
                                    <td>₡ @item.Total.ToString("N2")</td>

                                    <td>
                                        @if (item.Estado)
                                        {
                                            <span class="estado-activo">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="estado-inactivo">Inactivo</span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.EstadoRecepcion == "Recibida")
                                        {
                                            <span class="recepcion-recibida">Recibida</span>
                                        }
                                        else
                                        {
                                            <span class="recepcion-pendiente">Pendiente</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="acciones-ordenes">
                                            <a href="@Url.Action("VerDetalleOrdenCompra", "DetalleOrdenCompra", new { q = item.OrdenCompraID })"
                                               class="btn-accion-orden btn-detalle-orden">
                                                Detalle
                                            </a>

                                            <a href="@Url.Action("ActualizarOrdenCompra", "OrdenesCompra", new { q = item.OrdenCompraID })"
                                               class="btn-accion-orden btn-editar-orden">
                                                Editar
                                            </a>

                                            @if (item.Estado && item.EstadoRecepcion == "Pendiente")
                                            {
                                                using (Html.BeginForm("RecibirOrdenCompra", "OrdenesCompra", FormMethod.Post, new { style = "display:inline;" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    @Html.Hidden("q", item.OrdenCompraID)

                                                    <button type="submit"
                                                            class="btn-accion-orden btn-recibir-orden"
                                                            onclick="return confirm('¿Seguro que deseas recibir esta orden y actualizar el inventario?')">
                                                        Recibir
                                                    </button>
                                                }
                                            }

                                            @using (Html.BeginForm("CambiarEstadoOrdenCompra", "OrdenesCompra", FormMethod.Post, new { style = "display:inline;" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                @Html.Hidden("q", item.OrdenCompraID)

                                                if (item.Estado)
                                                {
                                                    <button type="submit"
                                                            class="btn-accion-orden btn-desactivar-orden">
                                                        Desactivar
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit"
                                                            class="btn-accion-orden btn-activar-orden">
                                                        Activar
                                                    </button>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {

            if ($.fn.DataTable.isDataTable('#tablaOrdenesCompra')) {
                return;
            }

            var table = $('#tablaOrdenesCompra').DataTable({
                destroy: true,
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                pageLength: 5,
                order: [[0, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [6] }
                ],
                dom: 't<"bottom"ip>'
            });

            function actualizarDashboard() {

                let total = 0;
                let activas = 0;
                let pendientes = 0;
                let monto = 0;

                table.rows({ search: 'applied' }).every(function () {

                    let data = this.data();

                    let estado = data[4];
                    let recepcion = data[5];
                    let totalTexto = data[3];

                    total++;

                    if (estado.includes("Activo")) activas++;
                    if (recepcion.includes("Pendiente")) pendientes++;

                    let numero = parseFloat(totalTexto.replace(/[₡, ]/g, ""));
                    monto += numero;
                });

                $(".card-total .ordenes-value").text(total);
                $(".card-activas .ordenes-value").text(activas);
                $(".card-pendientes .ordenes-value").text(pendientes);
                $(".card-monto .ordenes-value").text("₡ " + monto.toLocaleString(undefined, { minimumFractionDigits: 2 }));
            }

            actualizarDashboard();

            table.on('draw', function () {
                actualizarDashboard();
            });

            $('#filtroProveedor').on('keyup', function () {
                table.column(1).search(this.value).draw();
            });

            $('#filtroEstado').on('change', function () {
                table.column(4).search(this.value).draw();
            });

            $('#filtroRecepcion').on('change', function () {
                table.column(5).search(this.value).draw();
            });

            $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {

                let fecha = data[2]; 
                let desde = $('#filtroFechaDesde').val();
                let hasta = $('#filtroFechaHasta').val();

                if (!fecha) return true;

                let partes = fecha.split('/');
                let fechaRow = new Date(partes[2], partes[1] - 1, partes[0]);

                if (desde) {
                    let fDesde = new Date(desde);
                    if (fechaRow < fDesde) return false;
                }

                if (hasta) {
                    let fHasta = new Date(hasta);
                    if (fechaRow > fHasta) return false;
                }

                return true;
            });

            $('#filtroFechaDesde, #filtroFechaHasta').on('change', function () {
                table.draw();
            });

        });
    </script>
}