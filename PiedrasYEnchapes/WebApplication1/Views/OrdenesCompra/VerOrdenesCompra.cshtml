@model List<WebApplication1.Models.OrdenCompra>

@{
    ViewBag.Title = "Órdenes de Compra";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<!-- ordenes section -->
<section class="food_section layout_padding-bottom layout_padding-top">

    <div class="container">

        <!-- ENCABEZADO -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div class="heading_container">
                <h2>Órdenes de Compra</h2>
                <p>Listado general de órdenes registradas en el sistema</p>
            </div>

            <a href="@Url.Action("AgregarOrdenCompra", "OrdenesCompra")"
               class="btn btn-success shadow-sm">
                Crear Orden
            </a>

        </div>

        <!-- MENSAJES -->
        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success">
                @TempData["Mensaje"]
            </div>
        }

        <!-- TABLA -->
        <div class="card shadow-sm">
            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-striped table-hover align-middle">

                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Proveedor</th>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>@item.OrdenCompraID</td>

                                    <td>@item.NombreProveedor</td>

                                    <td>
                                        @item.FechaOrden.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        ₡ @item.Total.ToString("N2")
                                    </td>

                                    <td>

                                        @if (item.Estado)
                                        {
                                            <span class="badge bg-success p-2">
                                                Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger p-2">
                                                Inactivo
                                            </span>
                                        }

                                    </td>

                                    <td class="text-center">

                                        <!-- EDITAR -->
                                        <a href="@Url.Action("ActualizarOrdenCompra",
                                            "OrdenesCompra",
                                            new { q = item.OrdenCompraID })"
                                           class="btn btn-warning btn-sm me-2">
                                            Editar
                                        </a>

                                        <a href="@Url.Action("VerDetalleOrdenCompra", "DetalleOrdenCompra", new { q = item.OrdenCompraID })"
                                           class="btn btn-info btn-sm me-2">
                                            Detalle
                                        </a>

                                        <!-- ACTIVAR / DESACTIVAR -->
                                        @using (Html.BeginForm("CambiarEstadoOrdenCompra",
                                            "OrdenesCompra",
                                            FormMethod.Post))
                                        {
                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="q"
                                                   value="@item.OrdenCompraID" />

                                            if (item.Estado)
                                            {
                                                <button type="submit"
                                                        class="btn btn-danger btn-sm">
                                                    Desactivar
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit"
                                                        class="btn btn-success btn-sm">
                                                    Activar
                                                </button>
                                            }
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>
        </div>

    </div>

</section>

