@model List<WebApplication1.Models.DetalleCompraModel>

@{
    ViewBag.Title = "Detalle de Compra";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    .detalle-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .detalle-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .detalle-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 18px;
    }

    .detalle-title {
        font-size: 26px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 8px;
    }

    .detalle-subtitle {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 20px;
    }

    table thead th {
        background: #111827;
        color: #fff;
    }

    .btn-volver {
        display: inline-block;
        margin-bottom: 18px;
        background: #111827;
        color: #fff;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
    }

        .btn-volver:hover {
            background: #000;
            color: #fff;
            text-decoration: none;
        }

    .alert-detalle {
        background: #fef3c7;
        color: #92400e;
        border: 1px solid #fde68a;
        border-radius: 12px;
        padding: 14px 16px;
        font-weight: 600;
    }
</style>

<section class="detalle-section">
    <div class="detalle-container">

        <a href="@Url.Action("HistorialCompras", "Cliente")" class="btn-volver">
            Volver al historial
        </a>

        <div class="detalle-card">
            <h2 class="detalle-title">Detalle de Compra #@ViewBag.CompraID</h2>
            <p class="detalle-subtitle">
                Consulta el detalle de productos incluidos en esta compra.
            </p>

            @if (Model == null || !Model.Any())
            {
                <div class="alert-detalle">
                    No hay detalle disponible para esta compra.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Cantidad</th>
                                <th>Precio Unitario</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.NombreProducto</td>
                                    <td>@item.Cantidad</td>
                                    <td>₡ @item.PrecioUnitario.ToString("N2")</td>
                                    <td>₡ @item.Subtotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</section>