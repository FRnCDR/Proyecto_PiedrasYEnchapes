@model List<WebApplication1.Models.HistorialCompra>

@{
    ViewBag.Title = "Historial de Compras";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";

    var totalCompras = Model != null ? Model.Count : 0;
    var comprasCompletadas = Model != null ? Model.Count(x => x.Estado == "Completada") : 0;
    var comprasPendientes = Model != null ? Model.Count(x => x.Estado == "Pendiente") : 0;
    var montoTotal = Model != null ? Model.Sum(x => x.Total) : 0;
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    .historial-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .historial-container {
        max-width: 1250px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .historial-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .historial-title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #111827;
    }

    .historial-subtitle {
        margin: 5px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .historial-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-historial-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-historial-primary:hover {
            background: #000;
            color: #fff;
        }

    .btn-historial-secondary {
        background: #16a34a;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-historial-secondary:hover {
            background: #15803d;
            color: #fff;
        }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        position: relative;
        overflow: hidden;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
        }

    .card-total::before {
        background: #2563eb;
    }

    .card-completadas::before {
        background: #16a34a;
    }

    .card-pendientes::before {
        background: #f59e0b;
    }

    .card-monto::before {
        background: #7c3aed;
    }

    .dashboard-label {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .dashboard-value {
        font-size: 30px;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
    }

    .dashboard-extra {
        margin-top: 8px;
        font-size: 13px;
        color: #9ca3af;
    }

    .historial-filtros {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

        .historial-filtros input,
        .historial-filtros select {
            border-radius: 999px;
            border: 1px solid #d1d5db;
            padding: 8px 14px;
            font-size: 14px;
            background: #fff;
        }

    .historial-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 18px;
    }

    .historial-card-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 14px;
    }

    table.dataTable thead th {
        background: #111827;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border-bottom: none;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        font-size: 14px;
    }

    .dataTables_wrapper .dataTables_paginate {
        margin-top: 15px;
        text-align: center;
    }

    .btn-danger {
        background-color: red;
        color: white; 
        text-align: center;
        padding: 10px 20px; 
        border-radius: 5px; 
        text-decoration: none; 
        font-weight: bold; 
    }

        .btn-danger:hover {
            background-color: darkred; 
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            background: #f3f4f6 !important;
            border: none !important;
            border-radius: 999px !important;
            padding: 6px 14px !important;
            margin: 0 4px;
            font-size: 14px;
            font-weight: 600;
            color: #111827 !important;
            cursor: pointer !important;
            transition: all 0.2s ease-in-out;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background: #111827 !important;
                color: #fff !important;
                transform: translateY(-1px);
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #facc15 !important;
                color: #111827 !important;
                font-weight: 700;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
                background: #e5e7eb !important;
                color: #9ca3af !important;
                cursor: not-allowed !important;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.previous,
            .dataTables_wrapper .dataTables_paginate .paginate_button.next {
                font-weight: 700;
            }

    .estado-completada {
        background: #dcfce7;
        color: #166534;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-pendiente {
        background: #fef3c7;
        color: #92400e;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-cancelada {
        background: #fee2e2;
        color: #991b1b;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .actions-cell {
        display: flex;
        gap: 8px;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action-table {
        min-width: 100px;
        height: 36px;
        border: none;
        border-radius: 999px;
        font-weight: 600;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.2s ease-in-out;
        cursor: pointer;
        padding: 0 14px;
        color: #fff;
    }

        .btn-action-table:hover {
            transform: translateY(-1px);
            color: #fff;
            text-decoration: none;
        }

    .btn-action-detalle {
        background: #2563eb;
    }

        .btn-action-detalle:hover {
            background: #1d4ed8;
        }

    .historial-vacio {
        background: #dbeafe;
        color: #1d4ed8;
        border: 1px solid #93c5fd;
        border-radius: 12px;
        padding: 16px;
        font-weight: 600;
    }

    @@media (max-width: 992px) {
        .dashboard-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .historial-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .historial-card {
            padding: 12px;
        }
    }
</style>

<section class="historial-section">
    <div class="historial-container">

        <div class="historial-head">
            <div>
                <h2 class="historial-title">Historial de Compras</h2>
                <p class="historial-subtitle">
                    Visualiza y controla todas las compras realizadas dentro del sistema.
                </p>
            </div>

            <div class="historial-actions">
                <a href="@Url.Action("VerProductos", "Productos")" class="btn btn-historial-primary">
                    Seguir comprando
                </a>

                <a href="@Url.Action("VerCarrito", "Carrito")" class="btn btn-historial-secondary">
                    Ver carrito
                </a>
            </div>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="historial-vacio">
                No tienes compras registradas.
            </div>
        }
        else
        {
            <div class="dashboard-grid">
                <div class="dashboard-card card-total">
                    <div class="dashboard-label">Total de compras</div>
                    <div class="dashboard-value">@totalCompras</div>
                    <div class="dashboard-extra">Compras registradas en el sistema</div>
                </div>

                <div class="dashboard-card card-completadas">
                    <div class="dashboard-label">Completadas</div>
                    <div class="dashboard-value">@comprasCompletadas</div>
                    <div class="dashboard-extra">Compras finalizadas correctamente</div>
                </div>

                <div class="dashboard-card card-pendientes">
                    <div class="dashboard-label">Pendientes</div>
                    <div class="dashboard-value">@comprasPendientes</div>
                    <div class="dashboard-extra">Compras aún en proceso</div>
                </div>

                <div class="dashboard-card card-monto">
                    <div class="dashboard-label">Monto total</div>
                    <div class="dashboard-value">₡ @montoTotal.ToString("N2")</div>
                    <div class="dashboard-extra">Monto acumulado de compras</div>
                </div>
            </div>

            <div class="historial-filtros">
                <input type="text" id="filtroBusquedaCompra" placeholder="Buscar por ID o estado..." />

                <select id="filtroEstadoCompra">
                    <option value="">Todos los estados</option>
                    <option value="Completada">Completada</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Cancelada">Cancelada</option>
                </select>

                <input type="date" id="filtroFechaDesdeCompra" />
                <input type="date" id="filtroFechaHastaCompra" />
            </div>

            <div class="historial-card">
                <h3 class="historial-card-title">Listado de compras</h3>

                <div class="table-responsive" style="overflow: visible;">
                    <table id="tablaHistorialCompras" class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID Compra</th>
                                <th>Fecha</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th style="width: 120px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.CompraID</td>
                                    <td>@item.FechaCompra.ToString("dd/MM/yyyy")</td>
                                    <td data-valor="@item.Total.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                        ₡ @item.Total.ToString("N2")
                                    </td>
                                    <td>
                                        @if (item.Estado == "Completada")
                                        {
                                            <span class="estado-completada">Completada</span>
                                        }
                                        else if (item.Estado == "Pendiente")
                                        {
                                            <span class="estado-pendiente">Pendiente</span>
                                        }
                                        else
                                        {
                                            <span class="estado-cancelada">Cancelada</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="actions-cell">
                                            <a href="@Url.Action("DetalleCompra", "Cliente", new { id = item.CompraID })"
                                               class="btn-action-table btn-action-detalle">
                                                Ver detalle
                                            </a>
                                            <a href="@Url.Action("DescargarPdf", "Cliente", new { compraId = item.CompraID })" class="btn-danger">
                                                Descargar PDF
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

    </div>
</section>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {

            if (!$('#tablaHistorialCompras').length) {
                return;
            }

            if ($.fn.DataTable.isDataTable('#tablaHistorialCompras')) {
                return;
            }

            var table = $('#tablaHistorialCompras').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json',
                    paginate: {
                        previous: "← Anterior",
                        next: "Siguiente →"
                    }
                },
                pageLength: 5,
                order: [[0, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [4] }
                ],
                dom: 't<"bottom"ip>'
            });

            function actualizarDashboard() {
                let total = 0;
                let completadas = 0;
                let pendientes = 0;
                let monto = 0;

                table.rows({ search: 'applied' }).every(function () {
                    let data = this.data();
                    let fila = $(this.node());

                    let estado = data[3];
                    let montoValor = parseFloat(fila.find('td:eq(2)').attr('data-valor')) || 0;

                    total++;

                    if (estado.includes("Completada")) completadas++;
                    if (estado.includes("Pendiente")) pendientes++;

                    monto += montoValor;
                });

                $(".card-total .dashboard-value").text(total);
                $(".card-completadas .dashboard-value").text(completadas);
                $(".card-pendientes .dashboard-value").text(pendientes);
                $(".card-monto .dashboard-value").text(
                    "₡ " + monto.toLocaleString('es-CR', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    })
                );
            }

            actualizarDashboard();

            table.on('draw', function () {
                actualizarDashboard();
            });

            $('#filtroBusquedaCompra').on('keyup', function () {
                table.search(this.value).draw();
            });

            $('#filtroEstadoCompra').on('change', function () {
                table.column(3).search(this.value).draw();
            });

            $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
                if (settings.nTable.id !== 'tablaHistorialCompras') {
                    return true;
                }

                let fecha = data[1];
                let desde = $('#filtroFechaDesdeCompra').val();
                let hasta = $('#filtroFechaHastaCompra').val();

                if (!fecha) return true;

                let partes = fecha.split('/');
                let fechaRow = new Date(partes[2], partes[1] - 1, partes[0]);

                if (desde) {
                    let fDesde = new Date(desde);
                    fDesde.setHours(0, 0, 0, 0);
                    if (fechaRow < fDesde) return false;
                }

                if (hasta) {
                    let fHasta = new Date(hasta);
                    fHasta.setHours(23, 59, 59, 999);
                    if (fechaRow > fHasta) return false;
                }

                return true;
            });

            $('#filtroFechaDesdeCompra, #filtroFechaHastaCompra').on('change', function () {
                table.draw();
            });
        });
    </script>
}