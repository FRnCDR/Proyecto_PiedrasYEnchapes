@{
    ViewBag.Title = "Clientes";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}
@model List<WebApplication1.Models.Cliente>

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<!-- clientes section -->
<section class="food_section layout_padding-bottom layout_padding-top">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="heading_container">
                <h2>Clientes</h2>
                <p>Listado general de clientes registrados en el sistema</p>
            </div>
            <a href="@Url.Action("AgregarCliente", "Cliente")" class="btn btn-success shadow-sm">
                Agregar Cliente
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered text-center table-sm">
                <thead class="thead-dark">
                    <tr>
                        <th>Identificación</th>
                        <th>Nombre Completo</th>
                        <th>Correo Electrónico</th>
                        <th>Teléfono</th>
                        <th>Dirección</th>
                        <th>Fecha Registro</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Identificacion</td>
                                <td class="text-truncate" style="max-width:180px;">@item.Nombre @item.Apellidos</td>
                                <td class="text-truncate" style="max-width:180px;">@item.CorreoElectronico</td>
                                <td>@item.Telefono</td>
                                <td class="text-truncate" style="max-width:200px;">@item.Direccion</td>
                                <td>@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge badge-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("ActualizarCliente", "Cliente", new { q = item.IdCliente })"
                                       class="btn btn-sm btn-warning">
                                        Editar
                                    </a>

                                    <a href="@Url.Action("CambiarEstadoCliente", "Cliente", new { q = item.IdCliente })"
                                       class="btn btn-sm @(item.Estado ? "btn-danger" : "btn-success")">
                                        @(item.Estado ? "Desactivar" : "Activar")
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8">No hay clientes registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>