@model List<WebApplication1.Models.Cliente>

@{
    ViewBag.Title = "Clientes";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";

    var totalClientes = Model != null ? Model.Count : 0;
    var clientesActivos = Model != null ? Model.Count(c => c.Estado) : 0;
    var clientesInactivos = Model != null ? Model.Count(c => !c.Estado) : 0;
    var clientesConTelefono = Model != null ? Model.Count(c => !string.IsNullOrEmpty(c.Telefono)) : 0;
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    .client-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .client-container {
        max-width: 1250px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .client-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .client-title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #111827;
    }

    .client-subtitle {
        margin: 5px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .client-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-client-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-client-primary:hover {
            background: #000;
            color: #fff;
        }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        position: relative;
        overflow: hidden;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
        }

    .card-total::before {
        background: #2563eb;
    }

    .card-active::before {
        background: #16a34a;
    }

    .card-inactive::before {
        background: #dc2626;
    }

    .card-phone::before {
        background: #7c3aed;
    }

    .dashboard-label {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .dashboard-value {
        font-size: 30px;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
    }

    .dashboard-extra {
        margin-top: 8px;
        font-size: 13px;
        color: #9ca3af;
    }

    .client-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 18px;
    }

    .client-card-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 14px;
    }

    table.dataTable thead th {
        background: #111827;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border-bottom: none;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        font-size: 14px;
    }

    .dataTables_wrapper .dataTables_filter input {
        border-radius: 999px;
        border: 1px solid #d1d5db;
        padding: 4px 10px;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 999px !important;
        padding: 4px 9px;
        margin: 0 2px;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: #facc15 !important;
            border-color: #facc15 !important;
            color: #111827 !important;
        }

    .estado-activo {
        background: #28a745;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-inactivo {
        background: #dc3545;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    @@media (max-width: 992px) {
        .dashboard-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .client-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .client-card {
            padding: 12px;
        }
    }
</style>

<section class="client-section">
    <div class="client-container">

        <div class="client-head">
            <div>
                <h2 class="client-title">Clientes</h2>
                <p class="client-subtitle">
                    Visualiza y administra el listado general de clientes registrados en el sistema.
                </p>
            </div>

            <div class="client-actions">
                <a href="@Url.Action("AgregarCliente", "Cliente")" class="btn btn-client-primary">
                    Agregar cliente
                </a>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="dashboard-card card-total">
                <div class="dashboard-label">Total de clientes</div>
                <div class="dashboard-value">@totalClientes</div>
                <div class="dashboard-extra">Clientes registrados en el sistema</div>
            </div>

            <div class="dashboard-card card-active">
                <div class="dashboard-label">Activos</div>
                <div class="dashboard-value">@clientesActivos</div>
                <div class="dashboard-extra">Clientes habilitados actualmente</div>
            </div>

            <div class="dashboard-card card-inactive">
                <div class="dashboard-label">Inactivos</div>
                <div class="dashboard-value">@clientesInactivos</div>
                <div class="dashboard-extra">Clientes deshabilitados</div>
            </div>

            <div class="dashboard-card card-phone">
                <div class="dashboard-label">Con teléfono</div>
                <div class="dashboard-value">@clientesConTelefono</div>
                <div class="dashboard-extra">Clientes con número registrado</div>
            </div>
        </div>

        <div class="client-card">
            <h3 class="client-card-title">Listado de clientes</h3>

            <div class="table-responsive">
                <table id="tablaClientes" class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Identificación</th>
                            <th>Nombre Completo</th>
                            <th>Correo Electrónico</th>
                            <th>Teléfono</th>
                            <th>Dirección</th>
                            <th>Fecha Registro</th>
                            <th>Estado</th>
                            <th style="width: 180px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Identificacion</td>
                                    <td>@item.Nombre @item.Apellidos</td>
                                    <td>@item.CorreoElectronico</td>
                                    <td>@item.Telefono</td>
                                    <td>@item.Direccion</td>
                                    <td>@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.Estado)
                                        {
                                            <span class="estado-activo">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="estado-inactivo">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("ActualizarCliente", "Cliente", new { q = item.IdCliente })"
                                           class="btn btn-sm btn-warning">
                                            Editar
                                        </a>

                                        <a href="@Url.Action("CambiarEstadoCliente", "Cliente", new { q = item.IdCliente })"
                                           class="btn btn-sm @(item.Estado ? "btn-danger" : "btn-success")">
                                            @(item.Estado ? "Desactivar" : "Activar")
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8">No hay clientes registrados.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#tablaClientes').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                pageLength: 10,
                order: [[1, 'asc']],
                columnDefs: [
                    { orderable: false, targets: [7] }
                ]
            });
        });
    </script>
}