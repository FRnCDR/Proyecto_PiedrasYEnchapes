@model List<WebApplication1.Models.Producto>

@{
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<section class="catalog-hero">
    <div class="catalog-hero-img">
        <img src="~/StaticFiles/images/productos-hero.png" alt="Piedras decorativas" />
    </div>

    <div class="catalog-hero-content">
        <span class="catalog-hero-pill">Catálogo</span>
        <h1>Piedras que transforman espacios</h1>
        <p>
            Selección curada de piedras y enchapes naturales para proyectos
            arquitectónicos, interiores y exteriores con carácter.
        </p>
    </div>
</section>

<section class="catalog_section">
    <div class="container">

        <div class="catalog-head">
            <div>
                <h2 class="catalog-title">Productos</h2>
                <p class="catalog-subtitle">Piedras y enchapes seleccionados para interiores y exteriores.</p>
            </div>

            <div class="catalog-search">
                <i class="fa fa-search"></i>
                <input type="text" id="buscarProducto" placeholder="Buscar producto..." />
            </div>
        </div>

        <ul class="filters_menu filters-minimal">
            <li class="active" data-filter="*">Todos</li>
        </ul>

        <div class="filters-content">
            <div class="row grid">

                @if (Model != null && Model.Any())
                {
                    var contador = 1;

                    foreach (var item in Model)
                    {
                        var numero = contador.ToString("D2");
                        var rutaImagen = !string.IsNullOrEmpty(item.Imagen)
                            ? Url.Content("~/StaticFiles/images/" + item.Imagen)
                            : Url.Content("~/StaticFiles/images/no-image.png");

                        <div class="col-sm-6 col-lg-4 all producto-item">
                            <article class="catalog-card">
                                <a class="catalog-img" href="@Url.Action("DetalleProducto", "Productos", new { id = item.ProductoID })">
                                    <img src="@rutaImagen" alt="@item.Nombre" />
                                </a>

                                <div class="catalog-body">
                                    <div class="catalog-topline">
                                        <span class="catalog-num">@numero</span>
                                        <div class="catalog-meta">
                                            <h5 class="catalog-name">@item.Nombre</h5>
                                            <p class="catalog-desc">@item.Descripcion</p>
                                        </div>
                                    </div>

                                    <div class="catalog-bottom">
                                        <span class="catalog-price">₡@item.Precio</span>
                                        <a class="catalog-link" href="@Url.Action("DetalleProducto", "Productos", new { id = item.ProductoID })">
                                            Ver detalle <span class="arrow">→</span>
                                        </a>
                                    </div>
                                </div>
                            </article>
                        </div>

                        contador++;
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-info text-center">
                            No hay productos disponibles en este momento.
                        </div>
                    </div>
                }

            </div>
        </div>

        <div class="catalog-cta">
            <a class="catalog-more" href="#">Ver más</a>
        </div>

    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const input = document.getElementById("buscarProducto");
            const productos = document.querySelectorAll(".producto-item");

            input.addEventListener("keyup", function () {
                const texto = input.value.toLowerCase().trim();

                productos.forEach(function (producto) {
                    const nombre = producto.querySelector(".catalog-name")?.textContent.toLowerCase() || "";
                    const descripcion = producto.querySelector(".catalog-desc")?.textContent.toLowerCase() || "";

                    if (nombre.includes(texto) || descripcion.includes(texto)) {
                        producto.style.display = "";
                    } else {
                        producto.style.display = "none";
                    }
                });
            });
        });
    </script>
}