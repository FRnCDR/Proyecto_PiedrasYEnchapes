@model List<WebApplication1.Models.FacturaCompra>

@{
    ViewBag.Title = "Todas las Facturas";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";

    var totalFacturas = Model != null ? Model.Count : 0;
    var facturasPendientes = Model != null ? Model.Count(f => f.Estado == "Pendiente") : 0;
    var facturasPagadas = Model != null ? Model.Count(f => f.Estado == "Pagada") : 0;
    var montoTotal = Model != null ? Model.Sum(f => f.MontoTotal) : 0;
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    .facturas-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .facturas-container {
        max-width: 1250px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .facturas-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .facturas-title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #111827;
    }

    .facturas-subtitle {
        margin: 5px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .facturas-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-facturas-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-facturas-primary:hover {
            background: #000;
            color: #fff;
        }

    .btn-facturas-secondary {
        background: #16a34a;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-facturas-secondary:hover {
            background: #15803d;
            color: #fff;
        }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        position: relative;
        overflow: hidden;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
        }

    .card-total::before {
        background: #2563eb;
    }

    .card-pendientes::before {
        background: #f59e0b;
    }

    .card-pagadas::before {
        background: #16a34a;
    }

    .card-monto::before {
        background: #7c3aed;
    }

    .dashboard-label {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .dashboard-value {
        font-size: 30px;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
    }

    .dashboard-extra {
        margin-top: 8px;
        font-size: 13px;
        color: #9ca3af;
    }

    .facturas-filtros {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

        .facturas-filtros input,
        .facturas-filtros select {
            border-radius: 999px;
            border: 1px solid #d1d5db;
            padding: 8px 14px;
            font-size: 14px;
            background: #fff;
        }

    .facturas-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 18px;
    }

    .facturas-card-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 14px;
    }

    table.dataTable thead th {
        background: #111827;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border-bottom: none;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        font-size: 14px;
    }

    .dataTables_wrapper .dataTables_paginate {
        margin-top: 15px;
        text-align: center;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            background: #f3f4f6 !important;
            border: none !important;
            border-radius: 999px !important;
            padding: 6px 14px !important;
            margin: 0 4px;
            font-size: 14px;
            font-weight: 600;
            color: #111827 !important;
            cursor: pointer !important;
            transition: all 0.2s ease-in-out;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background: #111827 !important;
                color: #fff !important;
                transform: translateY(-1px);
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #facc15 !important;
                color: #111827 !important;
                font-weight: 700;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
                background: #e5e7eb !important;
                color: #9ca3af !important;
                cursor: not-allowed !important;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.previous,
            .dataTables_wrapper .dataTables_paginate .paginate_button.next {
                font-weight: 700;
            }

    .estado-pendiente {
        background: #fef3c7;
        color: #92400e;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-pagada {
        background: #dcfce7;
        color: #166534;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .monto-pendiente {
        color: #b45309;
        font-weight: 700;
    }

    .monto-cubierto {
        color: #166534;
        font-weight: 700;
    }

    @@media (max-width: 992px) {
        .dashboard-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .facturas-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .facturas-card {
            padding: 12px;
        }
    }
</style>

<section class="facturas-section">
    <div class="facturas-container">

        <div class="facturas-head">
            <div>
                <h2 class="facturas-title">Todas las Facturas</h2>
                <p class="facturas-subtitle">
                    Visualiza y controla el historial general de facturas registradas con sus montos, fechas y estado.
                </p>
            </div>

            <div class="facturas-actions">
                <a href="@Url.Action("VerProveedores", "Proveedor")" class="btn btn-facturas-primary">
                    Ver proveedores
                </a>

                <a href="@Url.Action("VerOrdenesCompra", "OrdenesCompra")" class="btn btn-facturas-secondary">
                    Ver órdenes
                </a>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="dashboard-card card-total">
                <div class="dashboard-label">Total de facturas</div>
                <div class="dashboard-value">@totalFacturas</div>
                <div class="dashboard-extra">Facturas registradas en el sistema</div>
            </div>

            <div class="dashboard-card card-pendientes">
                <div class="dashboard-label">Pendientes</div>
                <div class="dashboard-value">@facturasPendientes</div>
                <div class="dashboard-extra">Facturas con saldo pendiente</div>
            </div>

            <div class="dashboard-card card-pagadas">
                <div class="dashboard-label">Pagadas</div>
                <div class="dashboard-value">@facturasPagadas</div>
                <div class="dashboard-extra">Facturas canceladas completamente</div>
            </div>

            <div class="dashboard-card card-monto">
                <div class="dashboard-label">Monto total</div>
                <div class="dashboard-value">₡ @montoTotal.ToString("N2", new System.Globalization.CultureInfo("es-CR"))</div>
                <div class="dashboard-extra">Suma total facturada</div>
            </div>
        </div>

        <div class="facturas-filtros">
            <input type="text" id="filtroProveedor" placeholder="Buscar proveedor..." />

            <select id="filtroEstado">
                <option value="">Todos los estados</option>
                <option value="Pendiente">Pendiente</option>
                <option value="Pagada">Pagada</option>
            </select>

            <input type="date" id="filtroFechaDesde" />
            <input type="date" id="filtroFechaHasta" />
        </div>

        <div class="facturas-card">
            <h3 class="facturas-card-title">Listado de facturas</h3>

            <div class="table-responsive" style="overflow: visible;">
                <table id="tablaFacturas" class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Proveedor</th>
                            <th>Fecha Factura</th>
                            <th>Fecha Vencimiento</th>
                            <th>Monto Total</th>
                            <th>Monto Pagado</th>
                            <th>Saldo Pendiente</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var saldoPendiente = item.MontoTotal - item.MontoPagado;

                                <tr>
                                    <td>@item.FacturaCompraID</td>
                                    <td>@item.NombreProveedor</td>
                                    <td>@item.FechaFactura.ToString("dd/MM/yyyy")</td>
                                    <td>@item.FechaVencimiento.ToString("dd/MM/yyyy")</td>

                                    <td data-valor="@item.MontoTotal.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                        ₡ @item.MontoTotal.ToString("N2", new System.Globalization.CultureInfo("es-CR"))
                                    </td>

                                    <td data-valor="@item.MontoPagado.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                        ₡ @item.MontoPagado.ToString("N2", new System.Globalization.CultureInfo("es-CR"))
                                    </td>

                                    <td data-valor="@saldoPendiente.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                        @if (saldoPendiente > 0)
                                        {
                                            <span class="monto-pendiente">₡ @saldoPendiente.ToString("N2", new System.Globalization.CultureInfo("es-CR"))</span>
                                        }
                                        else
                                        {
                                            <span class="monto-cubierto">₡ 0,00</span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.Estado == "Pagada")
                                        {
                                            <span class="estado-pagada">Pagada</span>
                                        }
                                        else
                                        {
                                            <span class="estado-pendiente">Pendiente</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8">No hay facturas registradas.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {

            if ($.fn.DataTable.isDataTable('#tablaFacturas')) {
                return;
            }

            var table = $('#tablaFacturas').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json',
                    paginate: {
                        previous: "← Anterior",
                        next: "Siguiente →"
                    }
                },
                pageLength: 5,
                order: [[0, 'desc']],
                dom: 't<"bottom"ip>'
            });

            function actualizarDashboard() {
                let total = 0;
                let pendientes = 0;
                let pagadas = 0;
                let monto = 0;

                table.rows({ search: 'applied' }).every(function () {
                    let data = this.data();
                    let fila = $(this.node());

                    let estado = data[7];
                    let montoValor = parseFloat(fila.find('td:eq(4)').attr('data-valor')) || 0;

                    total++;

                    if (estado.includes("Pendiente")) pendientes++;
                    if (estado.includes("Pagada")) pagadas++;

                    monto += montoValor;
                });

                $(".card-total .dashboard-value").text(total);
                $(".card-pendientes .dashboard-value").text(pendientes);
                $(".card-pagadas .dashboard-value").text(pagadas);
                $(".card-monto .dashboard-value").text(
                    "₡ " + monto.toLocaleString('es-CR', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    })
                );
            }

            actualizarDashboard();

            table.on('draw', function () {
                actualizarDashboard();
            });

            $('#filtroProveedor').on('keyup', function () {
                table.column(1).search(this.value).draw();
            });

            $('#filtroEstado').on('change', function () {
                table.column(7).search(this.value).draw();
            });

            $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
                if (settings.nTable.id !== 'tablaFacturas') {
                    return true;
                }

                let fecha = data[2];
                let desde = $('#filtroFechaDesde').val();
                let hasta = $('#filtroFechaHasta').val();

                if (!fecha) return true;

                let partes = fecha.split('/');
                let fechaRow = new Date(partes[2], partes[1] - 1, partes[0]);

                if (desde) {
                    let fDesde = new Date(desde);
                    fDesde.setHours(0, 0, 0, 0);
                    if (fechaRow < fDesde) return false;
                }

                if (hasta) {
                    let fHasta = new Date(hasta);
                    fHasta.setHours(23, 59, 59, 999);
                    if (fechaRow > fHasta) return false;
                }

                return true;
            });

            $('#filtroFechaDesde, #filtroFechaHasta').on('change', function () {
                table.draw();
            });
        });
    </script>
}