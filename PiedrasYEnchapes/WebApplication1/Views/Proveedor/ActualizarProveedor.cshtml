@{
    ViewBag.Title = "Proveedores";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}
@model WebApplication1.Models.Proveedor

<!-- HERO GENERAL -->
<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<!-- proveedores section -->
<section class="food_section layout_padding-bottom layout_padding-top">

    <div class="container-fluid py-4">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-9">
                <div class="card shadow-sm border-0">
                    <div class="card-header pb-0 bg-transparent">
                        <h4 class="font-weight-bolder mb-1">Editar Proveedor</h4>
                        <p class="text-sm text-muted mb-0">
                            Modifica la información del proveedor seleccionado.
                        </p>
                    </div>

                    <div class="card-body pt-3">
                        @using (Html.BeginForm("ActualizarProveedor", "Proveedor", FormMethod.Post, new { @id = "FormActualizarProveedor" }))
                        {
                            @Html.HiddenFor(x => x.ProveedorID)

                            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                            <!-- Nombre de Empresa -->
                            <div class="mb-3">
                                <label class="form-label">Nombre de Empresa</label>
                                @Html.TextBoxFor(x => x.NombreEmpresa, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.NombreEmpresa, "", new { @class = "text-danger" })
                            </div>

                            <!-- Contacto -->
                            <div class="mb-3">
                                <label class="form-label">Contacto</label>
                                @Html.TextBoxFor(x => x.Contacto, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.Contacto, "", new { @class = "text-danger" })
                            </div>

                            <!-- Correo -->
                            <div class="mb-3">
                                <label class="form-label">Correo electrónico</label>
                                @Html.TextBoxFor(x => x.CorreoElectronico,
                                    new { @class = "form-control", type = "email" })
                                @Html.ValidationMessageFor(x => x.CorreoElectronico, "", new { @class = "text-danger" })
                            </div>

                            <!-- Teléfono -->
                            <div class="mb-3">
                                <label class="form-label">Teléfono</label>
                                @Html.TextBoxFor(x => x.Telefono, new { @class = "form-control" })
                                @Html.ValidationMessageFor(x => x.Telefono, "", new { @class = "text-danger" })
                            </div>

                            <!-- Dirección -->
                            <div class="mb-3">
                                <label class="form-label">Dirección</label>
                                @Html.TextAreaFor(x => x.Direccion,
                                    new { @class = "form-control", rows = 3 })
                                @Html.ValidationMessageFor(x => x.Direccion, "", new { @class = "text-danger" })
                            </div>

                            <!-- Tipo -->
                            <div class="mb-3">
                                <label class="form-label">Tipo</label>
                                @Html.DropDownListFor(
                                    x => x.Tipo,
                                    new List<SelectListItem>
                                    {
                                        new SelectListItem { Text = "Nacional", Value = "Nacional" },
                                        new SelectListItem { Text = "Internacional", Value = "Internacional" }
                                    },
                                    "-- Seleccione Tipo --",
                                    new { @class = "form-control" }
                                )
                                @Html.ValidationMessageFor(x => x.Tipo, "", new { @class = "text-danger" })
                            </div>

                            <!-- Fecha Registro (Solo lectura) -->
                            <div class="mb-3">
                                <label class="form-label">Fecha de Registro</label>
                                @Html.TextBoxFor(x => x.FechaRegistro,
                                    "{0:dd/MM/yyyy HH:mm}",
                                    new { @class = "form-control", @readonly = "readonly" })
                            </div>

                            <!-- Estado -->
                            <div class="form-check mb-3">
                                @Html.CheckBoxFor(x => x.Estado, new { @class = "form-check-input" })
                                <label class="form-check-label">Proveedor Activo</label>
                            </div>

                            <!-- Botón guardar -->
                            <div class="text-center">
                                <button type="submit" class="btn btn-success w-100 mb-0">
                                    Guardar cambios
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>