@{
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}
@model List<WebApplication1.Models.Proveedor>

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<!-- proveedores section -->
<section class="food_section layout_padding-bottom layout_padding-top">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="heading_container">
                <h2>Proveedores</h2>
                <p>Listado general de proveedores registrados en el sistema</p>
            </div>

            <div class="d-flex gap-2">
                <a href="@Url.Action("AgregarProveedor", "Proveedor")" class="btn btn-success shadow-sm">
                    Agregar Proveedor
                </a>

                <a href="@Url.Action("VerOrdenesCompra", "OrdenesCompra")" class="btn btn-primary shadow-sm">
                    Ver ordenes
                </a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered text-center table-sm">
                <thead class="thead-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Contacto</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Dirección</th>
                        <th>Tipo</th>
                        <th>Fecha Registro</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-truncate" style="max-width:120px;">@item.NombreEmpresa</td>
                                <td class="text-truncate" style="max-width:120px;">@item.Contacto</td>
                                <td>@item.Telefono</td>
                                <td class="text-truncate" style="max-width:150px;">@item.CorreoElectronico</td>
                                <td class="text-truncate" style="max-width:200px;">@item.Direccion</td>
                                <td>@item.Tipo</td>
                                <td>@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge badge-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("ActualizarProveedor", "Proveedor", new { id = item.ProveedorID })" class="btn btn-sm btn-warning">Editar</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9">No hay proveedores registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>