@model List<WebApplication1.Models.Proveedor>

@{
    ViewBag.Title = "Proveedores";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";

    var totalProveedores = Model != null ? Model.Count : 0;
    var proveedoresActivos = Model != null ? Model.Count(p => p.Estado) : 0;
    var proveedoresInactivos = Model != null ? Model.Count(p => !p.Estado) : 0;
    var nacionales = Model != null ? Model.Count(p => p.Tipo == "Nacional") : 0;
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    .provider-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .provider-container {
        max-width: 1250px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .provider-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .provider-title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #111827;
    }

    .provider-subtitle {
        margin: 5px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .provider-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-provider-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-provider-primary:hover {
            background: #000;
            color: #fff;
        }

    .btn-provider-secondary {
        background: #16a34a;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-provider-secondary:hover {
            background: #15803d;
            color: #fff;
        }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        position: relative;
        overflow: hidden;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
        }

    .card-total::before {
        background: #2563eb;
    }

    .card-active::before {
        background: #16a34a;
    }

    .card-inactive::before {
        background: #dc2626;
    }

    .card-national::before {
        background: #7c3aed;
    }

    .dashboard-label {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .dashboard-value {
        font-size: 30px;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
    }

    .dashboard-extra {
        margin-top: 8px;
        font-size: 13px;
        color: #9ca3af;
    }

    .provider-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 18px;
    }

    .provider-card-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 14px;
    }

    table.dataTable thead th {
        background: #111827;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border-bottom: none;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        font-size: 14px;
    }

    .dataTables_wrapper .dataTables_filter input {
        border-radius: 999px;
        border: 1px solid #d1d5db;
        padding: 4px 10px;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 999px !important;
        padding: 4px 9px;
        margin: 0 2px;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: #facc15 !important;
            border-color: #facc15 !important;
            color: #111827 !important;
        }

    .estado-activo {
        background: #28a745;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-inactivo {
        background: #dc3545;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .tipo-nacional {
        background: #dcfce7;
        color: #166534;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .tipo-internacional {
        background: #dbeafe;
        color: #1d4ed8;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    @@media (max-width: 992px) {
        .dashboard-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .provider-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .provider-card {
            padding: 12px;
        }
    }
</style>

<section class="provider-section">
    <div class="provider-container">

        <div class="provider-head">
            <div>
                <h2 class="provider-title">Proveedores</h2>
                <p class="provider-subtitle">
                    Visualiza y administra el listado general de proveedores registrados en el sistema.
                </p>
            </div>

            <div class="provider-actions">
                <a href="@Url.Action("AgregarProveedor", "Proveedor")" class="btn btn-provider-primary">
                    Agregar proveedor
                </a>

                <a href="@Url.Action("VerOrdenesCompra", "OrdenesCompra")" class="btn btn-provider-secondary">
                    Ver órdenes
                </a>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="dashboard-card card-total">
                <div class="dashboard-label">Total de proveedores</div>
                <div class="dashboard-value">@totalProveedores</div>
                <div class="dashboard-extra">Proveedores registrados en el sistema</div>
            </div>

            <div class="dashboard-card card-active">
                <div class="dashboard-label">Activos</div>
                <div class="dashboard-value">@proveedoresActivos</div>
                <div class="dashboard-extra">Proveedores disponibles actualmente</div>
            </div>

            <div class="dashboard-card card-inactive">
                <div class="dashboard-label">Inactivos</div>
                <div class="dashboard-value">@proveedoresInactivos</div>
                <div class="dashboard-extra">Proveedores deshabilitados</div>
            </div>

            <div class="dashboard-card card-national">
                <div class="dashboard-label">Nacionales</div>
                <div class="dashboard-value">@nacionales</div>
                <div class="dashboard-extra">Proveedores tipo nacional</div>
            </div>
        </div>

        <div class="provider-card">
            <h3 class="provider-card-title">Listado de proveedores</h3>

            <div class="table-responsive">
                <table id="tablaProveedores" class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Contacto</th>
                            <th>Teléfono</th>
                            <th>Email</th>
                            <th>Dirección</th>
                            <th>Tipo</th>
                            <th>Fecha Registro</th>
                            <th>Estado</th>
                            <th style="width: 120px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.NombreEmpresa</td>
                                    <td>@item.Contacto</td>
                                    <td>@item.Telefono</td>
                                    <td>@item.CorreoElectronico</td>
                                    <td>@item.Direccion</td>
                                    <td>
                                        @if (item.Tipo == "Nacional")
                                        {
                                            <span class="tipo-nacional">Nacional</span>
                                        }
                                        else
                                        {
                                            <span class="tipo-internacional">@item.Tipo</span>
                                        }
                                    </td>
                                    <td>@item.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.Estado)
                                        {
                                            <span class="estado-activo">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="estado-inactivo">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("ActualizarProveedor", "Proveedor", new { id = item.ProveedorID })"
                                           class="btn btn-sm btn-warning">
                                            Editar
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9">No hay proveedores registrados.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#tablaProveedores').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                pageLength: 10,
                order: [[0, 'asc']],
                columnDefs: [
                    { orderable: false, targets: [8] }
                ]
            });
        });
    </script>
}