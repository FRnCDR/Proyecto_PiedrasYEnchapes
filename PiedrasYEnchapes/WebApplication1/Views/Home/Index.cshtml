@model List<WebApplication1.EF.tbProductos>

@{
    ViewBag.Title = "Inicio";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<!-- HERO + FONDO + CARRUSEL (VERSIÓN ORIGINAL) -->
<div class="hero_area">
    <div class="bg-box">
        <img src="~/StaticFiles/images/fondoImagen.png" />
    </div>

    <section class="slider_section">
        <div id="customCarousel1" class="carousel slide" data-ride="carousel">
            <div class="carousel-inner">

                <div class="carousel-item active">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-7 col-lg-6">
                                <div class="detail-box">
                                    <h1>Los mejores proveedores de piedras decorativas</h1>
                                    <p>
                                        Ofrecemos productos de la más alta calidad para su negocio,
                                        seleccionados y fabricados con estándares profesionales.
                                    </p>
                                    <div class="btn-box">
                                        <a href="@Url.Action("VerCotizaciones", "Cotizacion")" class="btn1">¡Cotiza ya!</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="carousel-item">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-7 col-lg-6">
                                <div class="detail-box">
                                    <h1>Decoración natural para tu hogar</h1>
                                    <p>
                                        Dale un toque natural y moderno a tu hogar con piedra decorativa.
                                    </p>
                                    <div class="btn-box">
                                        <a href="@Url.Action("VerCotizaciones", "Cotizacion")" class="btn1">¡Cotiza ya!</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="carousel-item">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-7 col-lg-6">
                                <div class="detail-box">
                                    <h1>Gran variedad de productos</h1>
                                    <p>
                                        Materiales seleccionados para todo tipo de proyectos.
                                    </p>
                                    <div class="btn-box">
                                        <a href="@Url.Action("VerCotizaciones", "Cotizacion")" class="btn1">¡Cotiza ya!</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="container">
                <ol class="carousel-indicators">
                    <li data-target="#customCarousel1" data-slide-to="0" class="active"></li>
                    <li data-target="#customCarousel1" data-slide-to="1"></li>
                    <li data-target="#customCarousel1" data-slide-to="2"></li>
                </ol>
            </div>
        </div>
    </section>
</div>

<!-- SECCIÓN: PRODUCTOS DESTACADOS -->
<section class="section-modern">
    <div class="container">

        <div class="section-head">
            <div>
                <h2 class="section-title">Algunos de nuestros productos</h2>
                <p class="section-subtitle">Descubrí opciones reales para tu proyecto y cotizá fácilmente.</p>
            </div>
            <a class="section-link" href="@Url.Action("VerProductos", "Productos")">Ver catálogo completo <span>→</span></a>
        </div>

        <ul class="filters_menu filters-modern">
            <li class="active" data-filter="*">Todos</li>
        </ul>

        <div class="filters-content">
            <div class="row grid">

                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var rutaImagen = !string.IsNullOrEmpty(item.Imagen)
                            ? Url.Content("~/StaticFiles/images/" + item.Imagen)
                            : Url.Content("~/StaticFiles/images/no-image.png");

                        <div class="col-sm-6 col-lg-4 all">
                            <div class="product-card">
                                <div class="product-img">
                                    <img src="@rutaImagen" alt="@item.Nombre" />
                                    <span class="product-badge">Disponible</span>
                                </div>

                                <div class="product-body">
                                    <div class="product-top">
                                        <h5 class="product-title">@item.Nombre</h5>
                                        <div class="product-price">₡@item.Precio</div>
                                    </div>

                                    <p class="product-desc">@item.Descripcion</p>

                                    <div class="product-actions">
                                        <a href="@Url.Action("CrearCotizacion", "Cotizacion")" class="btn product-btn">
                                            Cotizar
                                        </a>

                                        <a href="@Url.Action("VerProductos", "Productos")" class="product-icon" title="Ver catálogo">
                                            <i class="fa fa-eye"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-info text-center">
                            No hay productos disponibles en este momento.
                        </div>
                    </div>
                }

            </div>
        </div>

        <div class="center-cta">
            <a class="btn big-cta" href="@Url.Action("VerProductos", "Productos")">Ver más productos</a>
        </div>

    </div>
</section>

<!-- ABOUT MODERNO -->
<section class="about-modern">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-md-6">
                <div class="about-card">
                    <img src="/StaticFiles/images/logoPiedras.jpg" alt="Logo" class="about-logo" />
                </div>
            </div>

            <div class="col-md-6">
                <div class="about-copy">
                    <h2>Somos Gustavo Fallas Piedras Enchapes y Más</h2>
                    <p>
                        Somos una empresa dedicada a la venta de piedras decorativas y enchapes.
                        Contamos con variedad para distintos estilos y proyectos, con calidad y atención personalizada.
                    </p>

                    <div class="about-features">
                        <div class="feature">
                            <i class="fa fa-check-circle"></i>
                            <span>Calidad garantizada</span>
                        </div>
                        <div class="feature">
                            <i class="fa fa-check-circle"></i>
                            <span>Asesoría para tu proyecto</span>
                        </div>
                        <div class="feature">
                            <i class="fa fa-check-circle"></i>
                            <span>Variedad y disponibilidad</span>
                        </div>
                    </div>

                    <div class="about-actions">
                        <a href="@Url.Action("VerNosotros", "SobreNosotros")" class="btn about-btn">Leer más</a>
                        <a href="@Url.Action("CrearCotizacion", "Cotizacion")" class="btn about-btn-ghost">Cotizar</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- TESTIMONIOS MODERNOS -->
<section class="testimonials-modern">
    <div class="container">
        <div class="section-head center">
            <div>
                <h2 class="section-title">Opiniones de nuestros clientes</h2>
                <p class="section-subtitle">Lo que más nos importa: que quedés satisfecho con el resultado.</p>
            </div>
        </div>

        <div class="row">

            <div class="col-md-6">
                <div class="t-card">
                    <div class="t-top">
                        <img src="~/StaticFiles/images/client1.jpg" class="t-avatar" alt="Cliente 1" />
                        <div>
                            <div class="t-name">Christina Fernandez</div>
                            <div class="t-role">Cliente</div>
                        </div>
                        <div class="t-stars">
                            <i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i>
                        </div>
                    </div>
                    <p class="t-text">
                        Excelente servicio, fueron de mucha ayuda en el asesoramiento a la hora de comprar los materiales.
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="t-card">
                    <div class="t-top">
                        <img src="~/StaticFiles/images/client2.jpg" class="t-avatar" alt="Cliente 2" />
                        <div>
                            <div class="t-name">Pedro Fernandez</div>
                            <div class="t-role">Cliente</div>
                        </div>
                        <div class="t-stars">
                            <i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i>
                        </div>
                    </div>
                    <p class="t-text">
                        Los productos que compré son de la mejor calidad. Recomendados totalmente.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>