@model WebApplication1.Models.Producto

@{
    ViewBag.Title = "Actualizar Producto";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<!-- HERO GENERAL -->
<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<!-- producto section -->
<section class="food_section layout_padding-bottom layout_padding-top">
    <div class="container-fluid py-4">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-9">

                <div class="card shadow-sm border-0">
                    <div class="card-header pb-0 bg-transparent">
                        <h4 class="font-weight-bolder mb-1">Actualizar Producto</h4>
                        <p class="text-sm text-muted mb-0">
                            Modifica la información del producto seleccionado.
                        </p>
                    </div>

                    <div class="card-body pt-3">
                        @using (Html.BeginForm("ActualizarProducto", "Inventario", FormMethod.Post, new { enctype = "multipart/form-data", id = "FormActualizarProducto" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(model => model.ProductoID)

                            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                            <!-- Nombre -->
                            <div class="mb-3">
                                <label class="form-label">Nombre del producto</label>
                                @Html.TextBoxFor(model => model.Nombre, new { @class = "form-control", placeholder = "Nombre del producto" })
                                @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
                            </div>

                            <!-- Descripción -->
                            <div class="mb-3">
                                <label class="form-label">Descripción</label>
                                @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control", rows = "3", placeholder = "Descripción del producto" })
                                @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                            </div>

                            <!-- Stock -->
                            <div class="mb-3">
                                <label class="form-label">Stock</label>
                                @Html.TextBoxFor(model => model.Stock, new { @class = "form-control", placeholder = "Stock disponible" })
                                @Html.ValidationMessageFor(model => model.Stock, "", new { @class = "text-danger" })
                            </div>

                            <!-- Precio -->
                            <div class="mb-3">
                                <label class="form-label">Precio</label>
                                @Html.TextBoxFor(model => model.Precio, new { @class = "form-control", placeholder = "Precio del producto" })
                                @Html.ValidationMessageFor(model => model.Precio, "", new { @class = "text-danger" })
                            </div>

                            <!-- Categoría -->
                            <div class="mb-3">
                                <label class="form-label">Categoría</label>
                                @Html.DropDownListFor(
                                    x => x.CategoriaID,
                                    (SelectList)ViewBag.Categorias,
                                    "Seleccione una categoría",
                                    new { @class = "form-control" }
                                )
                                @Html.ValidationMessageFor(x => x.CategoriaID, "", new { @class = "text-danger" })
                            </div>

                            <!-- Proveedor -->
                            <div class="mb-3">
                                <label class="form-label">Proveedor</label>
                                @Html.DropDownListFor(
                                    x => x.ProveedorID,
                                    (SelectList)ViewBag.Proveedores,
                                    "Seleccione un proveedor",
                                    new { @class = "form-control" }
                                )
                                @Html.ValidationMessageFor(x => x.ProveedorID, "", new { @class = "text-danger" })
                            </div>

                            <!-- Imagen -->
                            <div class="mb-3">
                                <label class="form-label">Imagen del producto</label>
                                <input type="file" name="Imagen" class="form-control" />
                                @Html.ValidationMessageFor(model => model.Imagen, "", new { @class = "text-danger" })
                            </div>

                            <!-- ImagenEjemplo -->
                            <div class="mb-3">
                                <label class="form-label">Imagen de ejemplo en entorno real</label>
                                <input type="file" name="ImagenEjemplo" class="form-control" />
                                @Html.ValidationMessageFor(model => model.ImagenEjemplo, "", new { @class = "text-danger" })
                            </div>

                            <!-- Botones -->
                            <div class="text-center">
                                <button type="submit" class="btn btn-success w-100 mb-2">
                                    Guardar Cambios
                                </button>

                                <a href="@Url.Action("VerInventario", "Inventario")" class="btn btn-secondary w-100">
                                    Cancelar
                                </a>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>