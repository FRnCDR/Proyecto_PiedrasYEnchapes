@model List<WebApplication1.Models.Producto>

@{
    ViewBag.Title = "Inventario";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<!-- HERO GENERAL -->
<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    /* Cabecera del módulo de inventario */
    .inventory-section {
        padding: 30px 0 40px;
    }

    .inventory-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .inventory-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
    }

    .inventory-title {
        margin: 0;
        font-size: 26px;
        font-weight: 700;
    }

    .inventory-subtitle {
        margin: 4px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .inventory-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    /* Botones más integrados al diseño */
    .btn-inventory-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 8px 14px;
        border-radius: 999px;
    }

        .btn-inventory-primary:hover {
            background: #000;
            color: #fff;
        }

    .btn-inventory-secondary {
        background: #16a34a;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 8px 14px;
        border-radius: 999px;
    }

        .btn-inventory-secondary:hover {
            background: #15803d;
            color: #fff;
        }

    /* Tarjeta de tabla */
    .inventory-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 16px;
    }

    /* Miniaturas */
    .inventory-thumb {
        border-radius: 6px;
        object-fit: cover;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

    /* DataTables: ajustes suaves */
    table.dataTable thead th {
        background: #111827;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border-bottom: none;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        font-size: 14px;
    }

    .dataTables_wrapper .dataTables_filter input {
        border-radius: 999px;
        border: 1px solid #d1d5db;
        padding: 4px 10px;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 999px !important;
        padding: 4px 9px;
        margin: 0 2px;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: #facc15 !important;
            border-color: #facc15 !important;
            color: #111827 !important;
        }

    <style >
    /* ...todo lo demas... */
    @@media (max-width: 768px) {
        .inventory-head {
            flex-direction: column;
        }

        .inventory-card {
            padding: 10px;
        }
    }
</style>

 

<section class="inventory-section">
    <div class="inventory-container">

        <!-- Header / acciones -->
        <div class="inventory-head">
            <div>
                <h2 class="inventory-title">Inventario de Productos</h2>
                <p class="inventory-subtitle">
                    Administra el stock, precios e imágenes de todos los productos.
                </p>
            </div>

            <div class="inventory-actions">
                <a href="@Url.Action("AgregarProducto", "Inventario")"
                   class="btn btn-inventory-primary">
                    Agregar nuevo producto
                </a>

                <a href="@Url.Action("VerCategorias", "Categoria")"
                   class="btn btn-inventory-secondary">
                    Ver lista de categorías
                </a>
            </div>
        </div>

        <!-- Tabla -->
        <div class="inventory-card">
            <div class="table-responsive">
                <table id="tablaInventario"
                       class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Stock</th>
                            <th>Precio</th>
                            <th>Imagen</th>
                            <th>Categoría</th>
                            <th style="width: 150px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var producto in Model)
                        {
                            <tr>
                                <td>@producto.Nombre</td>
                                <td>@producto.Descripcion</td>
                                <td>@producto.Stock</td>
                                <td>₡ @producto.Precio</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(producto.Imagen))
                                    {
                                        <img src="@Url.Content("~/" + producto.Imagen)"
                                             alt="@producto.Nombre"
                                             width="55"
                                             height="55"
                                             class="inventory-thumb" />
                                    }
                                </td>
                                <td>@producto.CategoriaID</td>
                                <td>
                                    <a href="@Url.Action("ActualizarProducto", "Inventario", new { q = producto.ProductoID })"
                                       class="btn btn-sm btn-warning">
                                        Editar
                                    </a>
                                    <a href="@Url.Action("EliminarProducto", "Inventario", new { q = producto.ProductoID })"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('¿Seguro que deseas eliminar este producto?');">
                                        Eliminar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <!-- DataTables (simple, sin integración especial con Bootstrap) -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#tablaInventario').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                pageLength: 10,
                order: [[0, 'asc']],
                columnDefs: [
                    { orderable: false, targets: [4, 6] } // imagen y acciones sin orden
                ]
            });
        });
    </script>
}