@model List<WebApplication1.Models.Producto>

@{
    ViewBag.Title = "Inventario";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";

    var totalProductos = Model != null ? Model.Count : 0;
    var stockTotal = Model != null ? Model.Sum(p => p.Stock) : 0;
    var productosStockBajo = Model != null ? Model.Count(p => p.Stock <= 5) : 0;
    var valorInventario = Model != null ? Model.Sum(p => p.Stock * p.Precio) : 0;
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    .inventory-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .inventory-container {
        max-width: 1250px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .inventory-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .inventory-title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #111827;
    }

    .inventory-subtitle {
        margin: 5px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .inventory-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-inventory-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-inventory-primary:hover {
            background: #000;
            color: #fff;
        }

    .btn-inventory-secondary {
        background: #16a34a;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-inventory-secondary:hover {
            background: #15803d;
            color: #fff;
        }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        position: relative;
        overflow: hidden;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
        }

    .card-total::before {
        background: #2563eb;
    }

    .card-stock::before {
        background: #16a34a;
    }

    .card-low::before {
        background: #f59e0b;
    }

    .card-value::before {
        background: #7c3aed;
    }

    .dashboard-label {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .dashboard-value {
        font-size: 30px;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
    }

    .dashboard-extra {
        margin-top: 8px;
        font-size: 13px;
        color: #9ca3af;
    }

    .inventory-alert {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .inventory-filtros {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

        .inventory-filtros input,
        .inventory-filtros select {
            border-radius: 999px;
            border: 1px solid #d1d5db;
            padding: 8px 14px;
            font-size: 14px;
            background: #fff;
        }

    .inventory-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 18px;
    }

    .inventory-card-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 14px;
    }

    .inventory-thumb {
        border-radius: 8px;
        object-fit: cover;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

    table.dataTable thead th {
        background: #111827;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border-bottom: none;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        font-size: 14px;
    }

    .dataTables_wrapper .dataTables_paginate {
        margin-top: 15px;
        text-align: center;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            background: #f3f4f6 !important;
            border: none !important;
            border-radius: 999px !important;
            padding: 6px 14px !important;
            margin: 0 4px;
            font-size: 14px;
            font-weight: 600;
            color: #111827 !important;
            cursor: pointer !important;
            transition: all 0.2s ease-in-out;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background: #111827 !important;
                color: #fff !important;
                transform: translateY(-1px);
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #facc15 !important;
                color: #111827 !important;
                font-weight: 700;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
                background: #e5e7eb !important;
                color: #9ca3af !important;
                cursor: not-allowed !important;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.previous,
            .dataTables_wrapper .dataTables_paginate .paginate_button.next {
                font-weight: 700;
            }

    .stock-bajo {
        background: #fef3c7;
        color: #92400e;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .stock-normal {
        background: #dcfce7;
        color: #166534;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-activo {
        background: #28a745;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-inactivo {
        background: #dc3545;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .actions-cell {
        display: flex;
        gap: 8px;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action-table {
        min-width: 95px;
        height: 36px;
        border: none;
        border-radius: 999px;
        font-weight: 600;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.2s ease-in-out;
        cursor: pointer;
        padding: 0 14px;
        color: #fff;
    }

        .btn-action-table:hover {
            transform: translateY(-1px);
            color: #fff;
            text-decoration: none;
        }

    .btn-action-edit {
        background: #f59e0b;
    }

        .btn-action-edit:hover {
            background: #d97706;
        }

    .btn-action-disable {
        background: #dc2626;
    }

        .btn-action-disable:hover {
            background: #b91c1c;
        }

    .btn-action-enable {
        background: #16a34a;
    }

        .btn-action-enable:hover {
            background: #15803d;
        }

    @@media (max-width: 992px) {
        .dashboard-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .inventory-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .inventory-card {
            padding: 12px;
        }
    }
</style>

<section class="inventory-section">
    <div class="inventory-container">

        <div class="inventory-head">
            <div>
                <h2 class="inventory-title">Inventario de Productos</h2>
                <p class="inventory-subtitle">
                    Visualiza el estado general del inventario y administra los productos registrados.
                </p>
            </div>

            <div class="inventory-actions">
                <a href="@Url.Action("AgregarProducto", "Inventario")" class="btn btn-inventory-primary">
                    Agregar nuevo producto
                </a>

                <a href="@Url.Action("VerCategorias", "Categoria")" class="btn btn-inventory-secondary">
                    Ver lista de categorías
                </a>
            </div>
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="inventory-alert">
                @TempData["Mensaje"]
            </div>
        }

        <div class="dashboard-grid">
            <div class="dashboard-card card-total">
                <div class="dashboard-label">Total de productos</div>
                <div class="dashboard-value">@totalProductos</div>
                <div class="dashboard-extra">Productos registrados en el sistema</div>
            </div>

            <div class="dashboard-card card-stock">
                <div class="dashboard-label">Stock total</div>
                <div class="dashboard-value">@stockTotal</div>
                <div class="dashboard-extra">Unidades disponibles en inventario</div>
            </div>

            <div class="dashboard-card card-low">
                <div class="dashboard-label">Stock bajo</div>
                <div class="dashboard-value">@productosStockBajo</div>
                <div class="dashboard-extra">Productos con 5 unidades o menos</div>
            </div>

            <div class="dashboard-card card-value">
                <div class="dashboard-label">Valor del inventario</div>
                <div class="dashboard-value">₡ @valorInventario.ToString("N2")</div>
                <div class="dashboard-extra">Cálculo basado en stock × precio</div>
            </div>
        </div>

        <div class="inventory-filtros">
            <input type="text" id="filtroBusquedaProducto" placeholder="Buscar nombre, descripción o proveedor..." />

            <select id="filtroEstadoProducto">
                <option value="">Todos los estados</option>
                <option value="Activo">Activo</option>
                <option value="Inactivo">Inactivo</option>
            </select>

            <select id="filtroStockProducto">
                <option value="">Todo el stock</option>
                <option value="StockBajo">Stock bajo</option>
                <option value="StockNormal">Stock normal</option>
            </select>
        </div>

        <div class="inventory-card">
            <h3 class="inventory-card-title">Listado de productos</h3>

            <div class="table-responsive" style="overflow: visible;">
                <table id="tablaInventario" class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Stock</th>
                            <th>Precio</th>
                            <th>Imagen</th>
                            <th>ID Categoría</th>
                            <th>Proveedor</th>
                            <th>Estado</th>
                            <th style="width: 220px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var producto in Model)
                        {
                            <tr>
                                <td>@producto.Nombre</td>
                                <td>@producto.Descripcion</td>

                                <td data-stock="@producto.Stock">
                                    @if (producto.Stock <= 5)
                                    {
                                        <span class="stock-bajo">@producto.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="stock-normal">@producto.Stock</span>
                                    }
                                </td>

                                <td data-precio="@producto.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                    ₡ @producto.Precio.ToString("N2")
                                </td>

                                <td>
                                    @if (!string.IsNullOrEmpty(producto.Imagen))
                                    {
                                        <img src="@Url.Content("~/StaticFiles/images/" + producto.Imagen)"
                                             alt="@producto.Nombre"
                                             width="55"
                                             height="55"
                                             class="inventory-thumb" />
                                    }
                                </td>

                                <td>@producto.CategoriaID</td>
                                <td>@producto.NombreEmpresa</td>

                                <td>
                                    @if (producto.Estado)
                                    {
                                        <span class="estado-activo">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="estado-inactivo">Inactivo</span>
                                    }
                                </td>

                                <td>
                                    <div class="actions-cell">
                                        <a href="@Url.Action("ActualizarProducto", "Inventario", new { q = producto.ProductoID })"
                                           class="btn-action-table btn-action-edit">
                                            Editar
                                        </a>

                                        @using (Html.BeginForm("CambiarEstadoProducto", "Inventario", FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            @Html.Hidden("q", producto.ProductoID)

                                            if (producto.Estado)
                                            {
                                                <button type="submit" class="btn-action-table btn-action-disable">
                                                    Desactivar
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn-action-table btn-action-enable">
                                                    Activar
                                                </button>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {

            if (!$('#tablaInventario').length) {
                return;
            }

            if ($.fn.DataTable.isDataTable('#tablaInventario')) {
                return;
            }

            var table = $('#tablaInventario').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json',
                    paginate: {
                        previous: "← Anterior",
                        next: "Siguiente →"
                    }
                },
                pageLength: 5,
                order: [[0, 'asc']],
                columnDefs: [
                    { orderable: false, targets: [4, 8] }
                ],
                dom: 't<"bottom"ip>'
            });

            function actualizarDashboard() {
                let total = 0;
                let stock = 0;
                let stockBajo = 0;
                let valor = 0;

                table.rows({ search: 'applied' }).every(function () {
                    let fila = $(this.node());
                    let stockFila = parseInt(fila.find('td:eq(2)').attr('data-stock')) || 0;
                    let precioFila = parseFloat(fila.find('td:eq(3)').attr('data-precio')) || 0;

                    total++;
                    stock += stockFila;
                    if (stockFila <= 5) stockBajo++;
                    valor += (stockFila * precioFila);
                });

                $(".card-total .dashboard-value").text(total);
                $(".card-stock .dashboard-value").text(stock);
                $(".card-low .dashboard-value").text(stockBajo);
                $(".card-value .dashboard-value").text(
                    "₡ " + valor.toLocaleString('es-CR', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    })
                );
            }

            actualizarDashboard();

            table.on('draw', function () {
                actualizarDashboard();
            });

            $('#filtroBusquedaProducto').on('keyup', function () {
                table.search(this.value).draw();
            });

            $('#filtroEstadoProducto').on('change', function () {
                table.column(7).search(this.value).draw();
            });

            $('#filtroStockProducto').on('change', function () {
                var valor = $(this).val();

                $.fn.dataTable.ext.search = $.fn.dataTable.ext.search.filter(function (fn) {
                    return fn.name !== "filtroStockProductoFn";
                });

                if (valor !== "") {
                    var filtroStockProductoFn = function (settings, data, dataIndex) {
                        if (settings.nTable.id !== 'tablaInventario') {
                            return true;
                        }

                        let fila = $(table.row(dataIndex).node());
                        let stock = parseInt(fila.find('td:eq(2)').attr('data-stock')) || 0;

                        if (valor === "StockBajo") {
                            return stock <= 5;
                        }

                        if (valor === "StockNormal") {
                            return stock > 5;
                        }

                        return true;
                    };

                    filtroStockProductoFn.name = "filtroStockProductoFn";
                    $.fn.dataTable.ext.search.push(filtroStockProductoFn);
                }

                table.draw();
            });
        });
    </script>
}