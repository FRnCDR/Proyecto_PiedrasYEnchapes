@model WebApplication1.Models.Producto

@{
    ViewBag.Title = "Agregar Producto";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<h2>Agregar Nuevo Producto</h2>

@using (Html.BeginForm("AgregarProducto", "Inventario", FormMethod.Post, new { @enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(model => model.Nombre)
        @Html.TextBoxFor(model => model.Nombre, new { @class = "form-control", placeholder = "Nombre del producto" })
        @Html.ValidationMessageFor(model => model.Nombre)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.Descripcion)
        @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control", rows = "3" })
        @Html.ValidationMessageFor(model => model.Descripcion)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.Stock)
        @Html.TextBoxFor(model => model.Stock, new { @class = "form-control", placeholder = "Stock" })
        @Html.ValidationMessageFor(model => model.Stock)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.Precio)
        @Html.TextBoxFor(model => model.Precio, new { @class = "form-control", placeholder = "Precio" })
        @Html.ValidationMessageFor(model => model.Precio)
    </div>

    <div class="mb-3">
        <label class="form-label">Categoría</label>
        @Html.DropDownListFor(
            x => x.CategoriaID,                     // Propiedad del modelo que guarda el ID
            (SelectList)ViewBag.Categorias,        // Lista de categorías enviada desde el controlador
            "Seleccione una categoría",             // Opción por defecto
            new { @class = "form-control" }        // Clases CSS
        )
        @Html.ValidationMessageFor(x => x.CategoriaID, "", new { @class = "text-danger" })
    </div>

    <!-- Selección de proveedor -->
    <div class="mb-3">
        <label class="form-label">Proveedor</label>
        @Html.DropDownListFor(x => x.ProveedorID, (SelectList)ViewBag.Proveedores, "Seleccione un proveedor", new { @class = "form-control" })
        @Html.ValidationMessageFor(x => x.ProveedorID, "", new { @class = "text-danger" })
    </div>

    <!-- Imagen -->
    <div class="form-group">
        @Html.LabelFor(model => model.Imagen)
        <input type="file" name="Imagen" class="form-control" />
        @Html.ValidationMessageFor(model => model.Imagen)
    </div>

    <button type="submit" class="btn btn-success">Guardar Producto</button>
    <a href="@Url.Action("VerInventario", "Inventario")" class="btn btn-secondary">Cancelar</a>
}