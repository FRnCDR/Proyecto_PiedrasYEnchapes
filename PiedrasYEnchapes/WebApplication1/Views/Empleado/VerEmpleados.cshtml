@model List<WebApplication1.Models.Empleado>

@{
    ViewBag.Title = "Empleados";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";

    var totalEmpleados = Model != null ? Model.Count : 0;
    var empleadosActivos = Model != null ? Model.Count(e => e.Estado) : 0;
    var empleadosInactivos = Model != null ? Model.Count(e => !e.Estado) : 0;
    var empleadosConTelefono = Model != null ? Model.Count(e => !string.IsNullOrEmpty(e.Telefono)) : 0;
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>

    .employee-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .employee-container {
        max-width: 1250px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .employee-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .employee-title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #111827;
    }

    .employee-subtitle {
        margin: 5px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .employee-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-employee-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-employee-primary:hover {
            background: #000;
            color: #fff;
        }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        position: relative;
        overflow: hidden;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
        }

    .card-total::before {
        background: #2563eb;
    }

    .card-active::before {
        background: #16a34a;
    }

    .card-inactive::before {
        background: #dc2626;
    }

    .card-phone::before {
        background: #7c3aed;
    }

    .dashboard-label {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .dashboard-value {
        font-size: 30px;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
    }

    .dashboard-extra {
        margin-top: 8px;
        font-size: 13px;
        color: #9ca3af;
    }

    .employee-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 18px;
    }

    .employee-card-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 14px;
    }

    table.dataTable thead th {
        background: #111827;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border-bottom: none;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        font-size: 14px;
    }

    .dataTables_wrapper .dataTables_filter input {
        border-radius: 999px;
        border: 1px solid #d1d5db;
        padding: 4px 10px;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 999px !important;
        padding: 4px 9px;
        margin: 0 2px;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: #facc15 !important;
            border-color: #facc15 !important;
            color: #111827 !important;
        }

    .estado-activo {
        background: #28a745;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-inactivo {
        background: #dc3545;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    @@media (max-width: 992px) {
        .dashboard-grid {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media (max-width: 768px) {
        .employee-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .employee-card {
            padding: 12px;
        }
    }
</style>

<section class="employee-section">
    <div class="employee-container">

        <div class="employee-head">

            <div>
                <h2 class="employee-title">Empleados</h2>
                <p class="employee-subtitle">
                    Visualiza y administra el listado general de empleados registrados en el sistema.
                </p>
            </div>

            <div class="employee-actions">
                <a href="@Url.Action("AgregarEmpleado","Empleado")"
                   class="btn btn-employee-primary">
                    Agregar empleado
                </a>
            </div>

        </div>

        <div class="dashboard-grid">

            <div class="dashboard-card card-total">
                <div class="dashboard-label">Total empleados</div>
                <div class="dashboard-value">@totalEmpleados</div>
                <div class="dashboard-extra">Empleados registrados</div>
            </div>

            <div class="dashboard-card card-active">
                <div class="dashboard-label">Activos</div>
                <div class="dashboard-value">@empleadosActivos</div>
                <div class="dashboard-extra">Empleados habilitados</div>
            </div>

            <div class="dashboard-card card-inactive">
                <div class="dashboard-label">Inactivos</div>
                <div class="dashboard-value">@empleadosInactivos</div>
                <div class="dashboard-extra">Empleados deshabilitados</div>
            </div>

            <div class="dashboard-card card-phone">
                <div class="dashboard-label">Con teléfono</div>
                <div class="dashboard-value">@empleadosConTelefono</div>
                <div class="dashboard-extra">Contactables</div>
            </div>

        </div>

        <div class="employee-card">

            <h3 class="employee-card-title">Listado de empleados</h3>

            <div class="table-responsive">
                <table id="tablaEmpleados" class="table table-striped table-hover align-middle">

                    <thead>
                        <tr>
                            <th>Nombre completo</th>
                            <th>Correo</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th style="width:200px;">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td>@item.NombreCompleto</td>
                                    <td>@item.Correo</td>
                                    <td>@item.Telefono</td>

                                    <td>
                                        @if (item.Estado)
                                        {
                                            <span class="estado-activo">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="estado-inactivo">Inactivo</span>
                                        }
                                    </td>

                                    <td>

                                        <a href="@Url.Action("ActualizarEmpleado","Empleado", new { q = item.IdEmpleado })"
                                           class="btn btn-sm btn-warning">
                                            Editar
                                        </a>

                                        <a href="@Url.Action("CambiarEstadoEmpleado","Empleado", new { q = item.IdEmpleado })"
                                           class="btn btn-sm @(item.Estado ? "btn-danger" : "btn-success")">
                                            @(item.Estado ? "Desactivar" : "Activar")
                                        </a>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5">No hay empleados registrados.</td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>

        </div>

    </div>
</section>

@section Scripts {

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
$(document).ready(function () {

$('#tablaEmpleados').DataTable({
language: {
url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
},
pageLength: 10,
order: [[0,'asc']],
columnDefs: [
{ orderable:false, targets:[4] }
]
});

});
    </script>

}