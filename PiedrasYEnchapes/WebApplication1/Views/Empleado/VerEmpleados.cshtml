@{
    ViewBag.Title = "Empleados";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}
@model List<WebApplication1.Models.Empleado>

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<!-- empleados section -->
<section class="food_section layout_padding-bottom layout_padding-top">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="heading_container">
                <h2>Empleados</h2>
                <p>Listado general de empleados registrados en el sistema</p>
            </div>
            <a href="@Url.Action("AgregarEmpleado", "Empleado")" class="btn btn-success shadow-sm">
                Agregar Empleado
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered text-center table-sm">
                <thead class="thead-dark">
                    <tr>
                        <th>Nombre completo</th>
                        <th>Correo</th>
                        <th>Teléfono</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-truncate" style="max-width:180px;">@item.NombreCompleto</td>
                                <td class="text-truncate" style="max-width:180px;">@item.Correo</td>
                                <td>@item.Telefono</td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge badge-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("ActualizarEmpleado", "Empleado", new { q = item.IdEmpleado })" class="btn btn-sm btn-warning">
                                        Editar
                                    </a>

                                    <a href="@Url.Action("CambiarEstadoEmpleado", "Empleado", new { q = item.IdEmpleado })"
                                       class="btn btn-sm @(item.Estado ? "btn-danger" : "btn-success")">
                                        @(item.Estado ? "Desactivar" : "Activar")
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">No hay empleados registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
<!-- end empleados section -->