@model List<WebApplication1.Models.Empleado>

@{
    ViewBag.Title = "Empleados";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";

    var totalEmpleados = Model != null ? Model.Count : 0;
    var empleadosActivos = Model != null ? Model.Count(e => e.Estado) : 0;
    var empleadosInactivos = Model != null ? Model.Count(e => !e.Estado) : 0;
    var empleadosConTelefono = Model != null ? Model.Count(e => !string.IsNullOrEmpty(e.Telefono)) : 0;
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>
    .employee-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .employee-container {
        max-width: 1250px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .employee-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .employee-title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #111827;
    }

    .employee-subtitle {
        margin: 5px 0 0;
        font-size: 14px;
        color: #6b7280;
    }

    .employee-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-employee-primary {
        background: #111827;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
    }

        .btn-employee-primary:hover {
            background: #000;
            color: #fff;
        }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 18px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        position: relative;
        overflow: hidden;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
        }

    .card-total::before {
        background: #2563eb;
    }

    .card-active::before {
        background: #16a34a;
    }

    .card-inactive::before {
        background: #dc2626;
    }

    .card-phone::before {
        background: #7c3aed;
    }

    .dashboard-label {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .dashboard-value {
        font-size: 30px;
        font-weight: 700;
        color: #111827;
        line-height: 1.1;
    }

    .dashboard-extra {
        margin-top: 8px;
        font-size: 13px;
        color: #9ca3af;
    }

    .employee-filtros {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

        .employee-filtros input,
        .employee-filtros select {
            border-radius: 999px;
            border: 1px solid #d1d5db;
            padding: 8px 14px;
            font-size: 14px;
            background: #fff;
        }

    .employee-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        padding: 18px;
    }

    .employee-card-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 14px;
    }

    table.dataTable thead th {
        background: #111827;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border-bottom: none;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        font-size: 14px;
    }

    .dataTables_wrapper .dataTables_paginate {
        margin-top: 15px;
        text-align: center;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            background: #f3f4f6 !important;
            border: none !important;
            border-radius: 999px !important;
            padding: 6px 14px !important;
            margin: 0 4px;
            font-size: 14px;
            font-weight: 600;
            color: #111827 !important;
            cursor: pointer !important;
            transition: all 0.2s ease-in-out;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background: #111827 !important;
                color: #fff !important;
                transform: translateY(-1px);
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background: #facc15 !important;
                color: #111827 !important;
                font-weight: 700;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
                background: #e5e7eb !important;
                color: #9ca3af !important;
                cursor: not-allowed !important;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.previous,
            .dataTables_wrapper .dataTables_paginate .paginate_button.next {
                font-weight: 700;
            }

    .estado-activo {
        background: #28a745;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .estado-inactivo {
        background: #dc3545;
        color: #fff;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-block;
    }

    .actions-cell {
        display: flex;
        gap: 8px;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action-table {
        min-width: 95px;
        height: 36px;
        border: none;
        border-radius: 999px;
        font-weight: 600;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.2s ease-in-out;
        cursor: pointer;
        padding: 0 14px;
        color: #fff;
    }

        .btn-action-table:hover {
            transform: translateY(-1px);
            color: #fff;
            text-decoration: none;
        }

    .btn-action-edit {
        background: #f59e0b;
    }

        .btn-action-edit:hover {
            background: #d97706;
        }

    .btn-action-disable {
        background: #dc2626;
    }

        .btn-action-disable:hover {
            background: #b91c1c;
        }

    .btn-action-enable {
        background: #16a34a;
    }

        .btn-action-enable:hover {
            background: #15803d;
        }

    @@media (max-width: 992px) {
        .dashboard-grid {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media (max-width: 768px) {
        .employee-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .employee-card {
            padding: 12px;
        }
    }
</style>

<section class="employee-section">
    <div class="employee-container">

        <div class="employee-head">
            <div>
                <h2 class="employee-title">Empleados</h2>
                <p class="employee-subtitle">
                    Visualiza y administra el listado general de empleados registrados en el sistema.
                </p>
            </div>

            <div class="employee-actions">
                <a href="@Url.Action("AgregarEmpleado","Empleado")" class="btn btn-employee-primary">
                    Agregar empleado
                </a>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="dashboard-card card-total">
                <div class="dashboard-label">Total empleados</div>
                <div class="dashboard-value">@totalEmpleados</div>
                <div class="dashboard-extra">Empleados registrados</div>
            </div>

            <div class="dashboard-card card-active">
                <div class="dashboard-label">Activos</div>
                <div class="dashboard-value">@empleadosActivos</div>
                <div class="dashboard-extra">Empleados habilitados</div>
            </div>

            <div class="dashboard-card card-inactive">
                <div class="dashboard-label">Inactivos</div>
                <div class="dashboard-value">@empleadosInactivos</div>
                <div class="dashboard-extra">Empleados deshabilitados</div>
            </div>

            <div class="dashboard-card card-phone">
                <div class="dashboard-label">Con teléfono</div>
                <div class="dashboard-value">@empleadosConTelefono</div>
                <div class="dashboard-extra">Contactables</div>
            </div>
        </div>

        <div class="employee-filtros">
            <input type="text" id="filtroBusquedaEmpleado" placeholder="Buscar nombre o correo..." />

            <select id="filtroEstadoEmpleado">
                <option value="">Todos los estados</option>
                <option value="Activo">Activo</option>
                <option value="Inactivo">Inactivo</option>
            </select>

            <select id="filtroTelefonoEmpleado">
                <option value="">Todos</option>
                <option value="ConTelefono">Con teléfono</option>
                <option value="SinTelefono">Sin teléfono</option>
            </select>
        </div>

        <div class="employee-card">
            <h3 class="employee-card-title">Listado de empleados</h3>

            <div class="table-responsive" style="overflow: visible;">
                <table id="tablaEmpleados" class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre completo</th>
                            <th>Correo</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th style="width:200px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.NombreCompleto</td>
                                    <td>@item.Correo</td>
                                    <td>@item.Telefono</td>
                                    <td>
                                        @if (item.Estado)
                                        {
                                            <span class="estado-activo">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="estado-inactivo">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="actions-cell">
                                            <a href="@Url.Action("ActualizarEmpleado","Empleado", new { q = item.IdEmpleado })"
                                               class="btn-action-table btn-action-edit">
                                                Editar
                                            </a>

                                            <a href="@Url.Action("CambiarEstadoEmpleado","Empleado", new { q = item.IdEmpleado })"
                                               class="btn-action-table @(item.Estado ? "btn-action-disable" : "btn-action-enable")">
                                                @(item.Estado ? "Desactivar" : "Activar")
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5">No hay empleados registrados.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {

            if (!$('#tablaEmpleados').length) {
                return;
            }

            if ($.fn.DataTable.isDataTable('#tablaEmpleados')) {
                return;
            }

            var table = $('#tablaEmpleados').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json',
                    paginate: {
                        previous: "← Anterior",
                        next: "Siguiente →"
                    }
                },
                pageLength: 5,
                order: [[0, 'asc']],
                columnDefs: [
                    { orderable: false, targets: [4] }
                ],
                dom: 't<"bottom"ip>'
            });

            function actualizarDashboard() {
                let total = 0;
                let activos = 0;
                let inactivos = 0;
                let conTelefono = 0;

                table.rows({ search: 'applied' }).every(function () {
                    let data = this.data();

                    let telefono = data[2] ? data[2].trim() : "";
                    let estado = data[3];

                    total++;

                    if (estado.includes("Activo")) activos++;
                    if (estado.includes("Inactivo")) inactivos++;
                    if (telefono !== "") conTelefono++;
                });

                $(".card-total .dashboard-value").text(total);
                $(".card-active .dashboard-value").text(activos);
                $(".card-inactive .dashboard-value").text(inactivos);
                $(".card-phone .dashboard-value").text(conTelefono);
            }

            actualizarDashboard();

            table.on('draw', function () {
                actualizarDashboard();
            });

            $('#filtroBusquedaEmpleado').on('keyup', function () {
                table.search(this.value).draw();
            });

            $('#filtroEstadoEmpleado').on('change', function () {
                table.column(3).search(this.value).draw();
            });

            $('#filtroTelefonoEmpleado').on('change', function () {
                var valor = $(this).val();

                $.fn.dataTable.ext.search = $.fn.dataTable.ext.search.filter(function (fn) {
                    return fn.name !== "filtroTelefonoEmpleadoFn";
                });

                if (valor !== "") {
                    var filtroTelefonoEmpleadoFn = function (settings, data, dataIndex) {
                        if (settings.nTable.id !== 'tablaEmpleados') {
                            return true;
                        }

                        let telefono = data[2] ? data[2].trim() : "";

                        if (valor === "ConTelefono") {
                            return telefono !== "";
                        }

                        if (valor === "SinTelefono") {
                            return telefono === "";
                        }

                        return true;
                    };

                    filtroTelefonoEmpleadoFn.name = "filtroTelefonoEmpleadoFn";
                    $.fn.dataTable.ext.search.push(filtroTelefonoEmpleadoFn);
                }

                table.draw();
            });
        });
    </script>
}