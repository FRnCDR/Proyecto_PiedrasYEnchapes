@model List<WebApplication1.Models.CotizacionLista>

@{
    ViewBag.Title = "Cotizaciones";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<style>

    .cotizacion-section {
        padding: 30px 0 40px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .cotizacion-container {
        max-width: 1200px;
        margin: auto;
        padding: 0 16px;
    }

    .cotizacion-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .cotizacion-title {
        font-size: 26px;
        font-weight: 700;
        margin: 0;
    }

    .cotizacion-subtitle {
        font-size: 14px;
        color: #6b7280;
        margin-top: 5px;
    }

    .btn-primary-custom {
        background: #111827;
        color: white;
        border: none;
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 600;
        text-decoration: none;
    }

        .btn-primary-custom:hover {
            background: black;
            color: white;
        }

    .btn-secondary-custom {
        background: #16a34a;
        color: white;
        border: none;
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 600;
        text-decoration: none;
    }

        .btn-secondary-custom:hover {
            background: #15803d;
            color: white;
        }

    .btn-danger-custom {
        background: #dc2626;
        color: white;
        border: none;
        padding: 5px 10px;
        border-radius: 999px;
    }

    .cotizacion-card {
        background: white;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    }

    table.dataTable thead th {
        background: #111827;
        color: white;
        font-size: 13px;
    }

    .estado-pendiente {
        background: #fef3c7;
        color: #92400e;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 600;
    }

    .estado-aprobada {
        background: #dcfce7;
        color: #166534;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 600;
    }

    .estado-rechazada {
        background: #fee2e2;
        color: #991b1b;
        padding: 5px 10px;
        border-radius: 999px;
        font-weight: 600;
    }

    .alert-success-custom {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 15px;
    }
</style>

<section class="cotizacion-section">
    <div class="cotizacion-container">

        <div class="cotizacion-head">

            <div>
                <h2 class="cotizacion-title">Cotizaciones</h2>
                <p class="cotizacion-subtitle">
                    Administra todas las cotizaciones creadas en el sistema.
                </p>
            </div>

            <div>
                <a href="@Url.Action("CrearCotizacion","Cotizacion")"
                   class="btn-primary-custom">
                    Nueva Cotización
                </a>
            </div>

        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert-success-custom">
                @TempData["Mensaje"]
            </div>
        }

        <div class="cotizacion-card">

            <div class="table-responsive">

                <table id="tablaCotizaciones" class="table table-striped table-hover align-middle">

                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Cliente</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th style="width:220px;">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {

                            <tr>

                                <td>@item.CotizacionID</td>

                                <td>@item.NombreCliente</td>

                                <td>@item.FechaCotizacion.ToShortDateString()</td>

                                <td>₡ @item.Total.ToString("N2")</td>

                                <td>

                                    @if (item.Estado == "Pendiente")
                                    {
                                        <span class="estado-pendiente">Pendiente</span>
                                    }
                                    else if (item.Estado == "Aprobada")
                                    {
                                        <span class="estado-aprobada">Aprobada</span>
                                    }
                                    else
                                    {
                                        <span class="estado-rechazada">@item.Estado</span>
                                    }

                                </td>

                                <td>

                                    <a href="@Url.Action("VerDetalleCotizacion","Cotizacion", new { q = item.CotizacionID })"
                                       class="btn btn-sm btn-primary">
                                        Ver
                                    </a>

                                    <a href="@Url.Action("AgregarDetalleCotizacion","Cotizacion", new { q = item.CotizacionID })"
                                       class="btn btn-sm btn-warning">
                                        Editar
                                    </a>

                                    @using (Html.BeginForm("CambiarEstadoCotizacion", "Cotizacion", FormMethod.Post, new { style = "display:inline;" }))
                                    {

                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("q", item.CotizacionID)
                                        @Html.Hidden("estado", "Aprobada")

                                        <button class="btn btn-sm btn-success">
                                            Aprobar
                                        </button>

                                    }

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
</section>

@section Scripts {

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>

$(document).ready(function () {

    $('#tablaCotizaciones').DataTable({
        language: {
            url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
        },
        pageLength: 10,
        order: [[0,'desc']]
    });

});

    </script>

}