@model List<WebApplication1.Models.CotizacionLista>

@{
    ViewBag.Title = "Cotizaciones";
    Layout = "~/Views/Shared/_LayoutInterno.cshtml";
}

<link href="~/StaticFiles/css/cotizaciones-cliente.css" rel="stylesheet" />

<div class="hero_general">
    <div class="bg-box">
        <img src="~/StaticFiles/images/navGeneral.jpg" />
    </div>
</div>

<section class="cotizaciones-cliente-section">
    <div class="cotizaciones-cliente-container">

        <div class="cotizaciones-hero">
            <div class="cotizaciones-hero-text">
                <span class="cotizaciones-eyebrow">Tus solicitudes</span>
                <h1 class="cotizaciones-main-title">Mis cotizaciones</h1>
                <p class="cotizaciones-main-subtitle">
                    Revisa el estado de tus cotizaciones, consulta los detalles y da seguimiento
                    a cada solicitud de forma simple y visual.
                </p>
            </div>

            <div class="cotizaciones-hero-action">
                <a href="@Url.Action("CrearCotizacion","Cotizacion")" class="btn-nueva-cotizacion">
                    <span class="btn-icon">＋</span>
                    Nueva cotización
                </a>
            </div>
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="cotizacion-alert-success">
                <span class="alert-dot"></span>
                <span>@TempData["Mensaje"]</span>
            </div>
        }

        <div class="cotizaciones-topbar">
            <div class="cotizaciones-topbar-left">
                <h2>Resumen</h2>
                <p>
                    @if (Model != null && Model.Any())
                    {
                        <text>Tienes @Model.Count cotización(es) registrada(s) en el sistema.</text>
                    }
                    else
                    {
                        <text>Aún no tienes cotizaciones registradas.</text>
                    }
                </p>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="cotizaciones-stats">
                    <div class="mini-stat">
                        <span class="mini-stat-label">Total</span>
                        <strong>@Model.Count</strong>
                    </div>
                    <div class="mini-stat">
                        <span class="mini-stat-label">Pendientes</span>
                        <strong>@Model.Count(x => x.Estado == "Pendiente")</strong>
                    </div>
                    <div class="mini-stat">
                        <span class="mini-stat-label">Aprobadas</span>
                        <strong>@Model.Count(x => x.Estado == "Aprobada")</strong>
                    </div>
                </div>
            }
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="cotizaciones-grid">

                @foreach (var item in Model.OrderByDescending(x => x.CotizacionID))
                {
                    var claseEstado = "estado-rechazada";
                    var iconoEstado = "✕";

                    if (item.Estado == "Pendiente")
                    {
                        claseEstado = "estado-pendiente";
                        iconoEstado = "◔";
                    }
                    else if (item.Estado == "Aprobada")
                    {
                        claseEstado = "estado-aprobada";
                        iconoEstado = "✓";
                    }

                    <article class="cotizacion-item-card reveal-card">
                        <div class="cotizacion-card-top">
                            <div class="cotizacion-card-id-wrap">
                                <span class="cotizacion-card-label">Cotización</span>
                                <h3 class="cotizacion-card-id">#@item.CotizacionID</h3>
                            </div>

                            <span class="cotizacion-estado-badge @claseEstado">
                                <span class="estado-icon">@iconoEstado</span>
                                @item.Estado
                            </span>
                        </div>

                        <div class="cotizacion-card-body">
                            <div class="cotizacion-data-block">
                                <span class="data-label">Cliente</span>
                                <span class="data-value">@item.NombreCliente</span>
                            </div>

                            <div class="cotizacion-data-row">
                                <div class="cotizacion-data-block">
                                    <span class="data-label">Fecha</span>
                                    <span class="data-value">@item.FechaCotizacion.ToShortDateString()</span>
                                </div>

                                <div class="cotizacion-data-block">
                                    <span class="data-label">Total estimado</span>
                                    <span class="data-value total-value">₡ @item.Total.ToString("N2")</span>
                                </div>
                            </div>
                        </div>

                        <div class="cotizacion-card-footer">
                            <a href="@Url.Action("VerDetalleCotizacion","Cotizacion", new { q = item.CotizacionID })"
                               class="btn-card-action btn-card-outline">
                                Ver detalle
                            </a>

                            <a href="@Url.Action("AgregarDetalleCotizacion","Cotizacion", new { q = item.CotizacionID })"
                               class="btn-card-action btn-card-soft">
                                Editar
                            </a>

                            @using (Html.BeginForm("CambiarEstadoCotizacion", "Cotizacion", FormMethod.Post, new { @class = "form-inline-action" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("q", item.CotizacionID)
                                @Html.Hidden("estado", "Aprobada")

                                <button type="submit" class="btn-card-action btn-card-success">
                                    Aprobar
                                </button>
                            }
                        </div>
                    </article>
                }

            </div>
        }
        else
        {
            <div class="cotizacion-empty-state">
                <div class="empty-icon">◌</div>
                <h3>Aún no tienes cotizaciones</h3>
                <p>
                    Cuando empieces a solicitar productos, aquí podrás ver el estado de cada cotización
                    de forma clara y ordenada.
                </p>

                <a href="@Url.Action("CrearCotizacion","Cotizacion")" class="btn-nueva-cotizacion">
                    <span class="btn-icon">＋</span>
                    Crear mi primera cotización
                </a>
            </div>
        }

    </div>
</section>

@section Scripts {
    <script src="~/StaticFiles/js/cotizaciones-cliente.js"></script>
}