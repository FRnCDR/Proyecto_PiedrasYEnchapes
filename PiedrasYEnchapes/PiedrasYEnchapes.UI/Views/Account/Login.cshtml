@using PiedrasYEnchapes.UI.Models
@model LoginViewModel

@{
    ViewBag.Title = "Iniciar sesión";
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
    ViewBag.BodyClass = "auth-bg";
}

<div class="auth-card-wrapper">
    <div class="card shadow-lg border-0 auth-card">
        <div class="card-body p-4 p-md-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold mb-1">Iniciar sesión</h2>
                <p class="text-muted mb-0">Accede con tu cuenta</p>
            </div>

            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            @using (Html.BeginForm("Login", "Account",
                new { ReturnUrl = ViewBag.ReturnUrl },
                FormMethod.Post,
                new { role = "form" }))
            {
                @Html.AntiForgeryToken()



                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">Correo electrónico</label>
                    @Html.TextBoxFor(m => m.Email, new
                    {
                        @class = "form-control form-control-lg",
                        placeholder = "correo@ejemplo.com",
                        autocomplete = "username"
                    })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    @Html.PasswordFor(m => m.Password, new
                    {
                        @class = "form-control form-control-lg",
                        placeholder = "••••••••",
                        autocomplete = "current-password"
                    })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                </div>

                <!-- Remember -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input", id = "rememberMe" })
                        <label class="form-check-label" for="rememberMe">
                            Recordarme
                        </label>
                    </div>
                </div>

                <!-- Button -->
                <button type="submit"
                        class="btn w-100 btn-lg"
                        style="background:#f4b740; color:#111; font-weight:700; border-radius:12px;">
                    Iniciar sesión
                </button>

                <div class="text-center mt-4">
                    <span class="text-muted">¿No tienes cuenta?</span>
                    <a href="@Url.Action("Register","Account")" class="fw-bold">
                        Registrarse
                    </a>
                </div>

                <div class="text-center mt-3">
                    <a href="@Url.Action("ForgotPassword","Account")" class="text-light fw-bold">
                        ¿Olvidaste tu contraseña?
                    </a>
                </div>

                <div class="text-center mt-4">
                    <a href="@Url.Action("Index","Home")" class="fw-bold">
                        Volver al menú principal
                    </a>
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
