@model PiedrasYEnchapes.UI.Models.RegisterViewModel

@{
    ViewBag.Title = "Registrarse";
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
    ViewBag.BodyClass = "auth-bg";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div class="col-12 col-md-9 col-lg-6">
        <div class="card shadow-lg border-0" style="border-radius:18px;">
            <div class="card-body p-4 p-md-5">

                <div class="text-center mb-4">
                    <h2 class="fw-bold mb-1">Crear cuenta</h2>
                    <p class="text-muted mb-0">Completa los datos para registrarte</p>
                </div>

                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label">Correo electrónico</label>
                        @Html.TextBoxFor(m => m.Email, new
                        {
                            @class = "form-control form-control-lg",
                            placeholder = "correo@ejemplo.com",
                            autocomplete = "username"
                        })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <label class="form-label">Contraseña</label>
                        @Html.PasswordFor(m => m.Password, new
                        {
                            @class = "form-control form-control-lg",
                            placeholder = "••••••••",
                            autocomplete = "new-password"
                        })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-3">
                        <label class="form-label">Confirmar contraseña</label>
                        @Html.PasswordFor(m => m.ConfirmPassword, new
                        {
                            @class = "form-control form-control-lg",
                            placeholder = "••••••••",
                            autocomplete = "new-password"
                        })
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                    </div>

                    <!-- Rol -->
                    <div class="mb-4">
                        <label class="form-label">Rol</label>
                        @Html.TextBoxFor(m => m.Rol, new
                        {
                            @class = "form-control form-control-lg",
                            placeholder = "Ej: Administrador, Empleado, Cliente"
                        })
                        @Html.ValidationMessageFor(m => m.Rol, "", new { @class = "text-danger small" })
                    </div>

                    <!-- Button -->
                    <button type="submit"
                            class="btn w-100 btn-lg"
                            style="background:#f4b740; color:#111; font-weight:700; border-radius:12px;">
                        Registrarse
                    </button>

                    <div class="text-center mt-4">
                        <span class="text-muted">¿Ya tienes cuenta?</span>
                        <a href="@Url.Action("Login","Account")" class="fw-bold">
                            Iniciar sesión
                        </a>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
