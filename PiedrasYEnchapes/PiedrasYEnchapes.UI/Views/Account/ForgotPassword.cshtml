@model PiedrasYEnchapes.UI.Models.ForgotPasswordViewModel

@{
    ViewBag.Title = "Restablecer contraseña";
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
    ViewBag.BodyClass = "auth-bg";
}

<div class="auth-card-wrapper">
    <div class="card shadow-lg border-0 auth-card">
        <div class="card-body p-4 p-md-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold mb-1">¿Olvidaste tu contraseña?</h2>
                <p class="text-muted mb-0">
                    Ingresa tu correo y te enviaremos un enlace para restablecerla
                </p>
            </div>

            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()

                <!-- Email -->
                <div class="mb-4">
                    <label class="form-label">Correo electrónico</label>
                    @Html.TextBoxFor(m => m.Email, new
                    {
                        @class = "form-control form-control-lg",
                        placeholder = "correo@ejemplo.com",
                        autocomplete = "email"
                    })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>

                <!-- Button -->
                <button type="submit"
                        class="btn w-100 btn-lg"
                        style="background:#f4b740; color:#111; font-weight:700; border-radius:12px;">
                    Enviar enlace de recuperación
                </button>

                <div class="text-center mt-4">
                    <a href="@Url.Action("Login","Account")" class="fw-bold">
                        Volver a iniciar sesión
                    </a>
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
